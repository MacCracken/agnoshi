# test_core.tcyr -- core module unit tests

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fs.cyr"
include "lib/hashmap.cyr"
include "lib/tagged.cyr"

fn getenv(name) { return 0; }
fn ui_show_error(m) { return 0; }
fn ui_show_warning(m) { return 0; }
fn chrono_now_rfc3339() { return str_from("2026-01-01T00:00:00Z"); }

include "src/sanitize.cyr"
include "src/mode.cyr"
include "src/permissions.cyr"
include "src/config.cyr"
include "src/commands.cyr"
include "src/intent.cyr"
include "src/translate.cyr"
include "src/interpreter.cyr"

var pass_count = 0;
var fail_count = 0;

fn check(name, condition) {
    if (condition == 1) {
        pass_count = pass_count + 1;
    } else {
        fail_count = fail_count + 1;
        str_print(str_from("FAIL: "));
        println(name);
    }
}

fn main() {
    alloc_init();
    println("=== agnoshi core tests ===");
    check("mode display AUTO", streq(mode_display(Mode.AI_AUTONOMOUS), "AI-AUTO"));
    check("mode display ASSIST", streq(mode_display(Mode.AI_ASSISTED), "AI-ASSIST"));
    check("mode display HUMAN", streq(mode_display(Mode.HUMAN), "HUMAN"));
    check("mode display STRICT", streq(mode_display(Mode.STRICT), "STRICT"));

    check("autonomous yes", mode_ai_autonomous(Mode.AI_AUTONOMOUS) == 1);
    check("autonomous no", mode_ai_autonomous(Mode.HUMAN) == 0);

    check("available auto", mode_ai_available(Mode.AI_AUTONOMOUS) == 1);
    check("available human no", mode_ai_available(Mode.HUMAN) == 0);

    check("strict yes", mode_strict_approval(Mode.STRICT) == 1);
    check("strict no", mode_strict_approval(Mode.HUMAN) == 0);

    var mgr = ModeManager_new(Mode.HUMAN, 1);
    check("mgr initial", ModeManager_current(mgr) == Mode.HUMAN);

    var r = ModeManager_switch(mgr, Mode.AI_ASSISTED);
    check("switch ok", r == 0);
    check("switched", ModeManager_current(mgr) == Mode.AI_ASSISTED);

    r = ModeManager_revert(mgr);
    check("revert ok", r == 0);
    check("reverted", ModeManager_current(mgr) == Mode.HUMAN);

    r = ModeManager_revert(mgr);
    check("revert none", r == (0 - 1));

    var mgr2 = ModeManager_new(Mode.HUMAN, 0);
    r = ModeManager_switch(mgr2, Mode.AI_ASSISTED);
    check("disabled switch fails", r == (0 - 1));
    check("disabled unchanged", ModeManager_current(mgr2) == Mode.HUMAN);

    check("perm safe no approve", perm_requires_approval(PermissionLevel.SAFE) == 0);
    check("perm read no approve", perm_requires_approval(PermissionLevel.READ_ONLY) == 0);
    check("perm sys approve", perm_requires_approval(PermissionLevel.SYSTEM_WRITE) == 1);
    check("perm admin approve", perm_requires_approval(PermissionLevel.ADMIN) == 1);
    check("perm blocked approve", perm_requires_approval(PermissionLevel.BLOCKED) == 1);

    check("ai allows safe", perm_ai_allowed(PermissionLevel.SAFE) == 1);
    check("ai blocks blocked", perm_ai_allowed(PermissionLevel.BLOCKED) == 0);

    check("root safe", check_permission("root", PermissionLevel.SAFE) == 1);
    check("root admin", check_permission("root", PermissionLevel.ADMIN) == 1);
    check("user safe", check_permission("user", PermissionLevel.SAFE) == 1);
    check("user admin no", check_permission("user", PermissionLevel.ADMIN) == 0);
    check("user blocked no", check_permission("user", PermissionLevel.BLOCKED) == 0);

    var empty = vec_new();
    check("classify ls", analyze_command_permission("ls", empty, 0) == PermissionLevel.READ_ONLY);
    check("classify cat", analyze_command_permission("cat", empty, 0) == PermissionLevel.READ_ONLY);
    check("classify cd", analyze_command_permission("cd", empty, 0) == PermissionLevel.SAFE);
    check("classify cp", analyze_command_permission("cp", empty, 0) == PermissionLevel.USER_WRITE);
    check("classify apt", analyze_command_permission("apt", empty, 0) == PermissionLevel.ADMIN);
    check("classify dd", analyze_command_permission("dd", empty, 0) == PermissionLevel.BLOCKED);
    check("classify chmod", analyze_command_permission("chmod", empty, 0) == PermissionLevel.BLOCKED);

    check("classify absolute dd", analyze_command_permission("/usr/bin/dd", empty, 0) == PermissionLevel.BLOCKED);
    check("classify relative rm", analyze_command_permission("./chmod", empty, 0) == PermissionLevel.BLOCKED);

    var config = ShellConfig_default();
    check("config mode", load64(config) == Mode.AI_ASSISTED);
    check("config history", load64(config + 8) == 10000);
    check("config ai", load64(config + 16) == 1);
    check("config approval", load64(config + 32) == 300);

    check("builtin cd", is_builtin("cd") == 1);
    check("builtin exit", is_builtin("exit") == 1);
    check("builtin help", is_builtin("help") == 1);
    check("builtin mode", is_builtin("mode") == 1);
    check("not builtin ls", is_builtin("ls") == 0);
    check("not builtin git", is_builtin("git") == 0);

    var intent = Intent_new(IntentTag.LIST_FILES);
    check("intent tag", load64(intent) == IntentTag.LIST_FILES);
    check("intent field1 zero", load64(intent + 8) == 0);

    var opts = list_options_pack(1, 1, 0, 0, 1);
    check("opts all", list_options_all(opts) == 1);
    check("opts long", list_options_long(opts) == 1);
    check("opts human", list_options_human(opts) == 0);
    check("opts recursive", list_options_recursive(opts) == 1);

    var targs = vec_new();
    vec_push(targs, "-la");
    var t = Translation_new("ls", targs, "List files", PermissionLevel.READ_ONLY, "ls");
    check("translation cmd", streq(load64(t), "ls") == 1);
    check("translation perm", load64(t + 24) == PermissionLevel.READ_ONLY);

    var interp = Interpreter_new();
    check("parse empty unknown",
    load64(Interpreter_parse(interp, str_from(""))) == IntentTag.UNKNOWN);
    check("parse show files",
    load64(Interpreter_parse(interp, str_from("show me all files"))) == IntentTag.LIST_FILES);
    check("parse list directory",
    load64(Interpreter_parse(interp, str_from("list the directory"))) == IntentTag.LIST_FILES);
    check("parse cd",
    load64(Interpreter_parse(interp, str_from("cd /tmp"))) == IntentTag.CHANGE_DIR);
    check("parse go to",
    load64(Interpreter_parse(interp, str_from("go to /home"))) == IntentTag.CHANGE_DIR);
    check("parse find named",
    load64(Interpreter_parse(interp, str_from("find files named foo in /tmp"))) == IntentTag.FIND_FILES);
    check("parse search content",
    load64(Interpreter_parse(interp, str_from("search for hello in /tmp"))) == IntentTag.SEARCH_CONTENT);
    check("parse create dir",
    load64(Interpreter_parse(interp, str_from("create a directory named foo"))) == IntentTag.CREATE_DIR);
    check("parse remove",
    load64(Interpreter_parse(interp, str_from("remove the file foo.txt"))) == IntentTag.REMOVE);
    check("parse install",
    load64(Interpreter_parse(interp, str_from("install vim"))) == IntentTag.INSTALL_PACKAGE);
    check("parse git status",
    load64(Interpreter_parse(interp, str_from("git status"))) == IntentTag.GIT_STATUS);
    check("parse git commit",
    load64(Interpreter_parse(interp, str_from("git commit -m hello"))) == IntentTag.GIT_COMMIT);
    check("parse firewall list",
    load64(Interpreter_parse(interp, str_from("firewall list rules"))) == IntentTag.FIREWALL_LIST);
    check("parse pipeline",
    load64(Interpreter_parse(interp, str_from("ls | grep foo"))) == IntentTag.PIPELINE);

    check("query ip address NETWORK",
    load64(Interpreter_parse(interp, str_from("what is my ip address"))) == IntentTag.NETWORK_INFO);
    check("query my ip NETWORK",
    load64(Interpreter_parse(interp, str_from("my ip"))) == IntentTag.NETWORK_INFO);
    check("query ip route NETWORK",
    load64(Interpreter_parse(interp, str_from("ip route table"))) == IntentTag.NETWORK_INFO);
    check("query uptime SYSTEM",
    load64(Interpreter_parse(interp, str_from("uptime"))) == IntentTag.SYSTEM_INFO);
    check("query load avg SYSTEM",
    load64(Interpreter_parse(interp, str_from("load average"))) == IntentTag.SYSTEM_INFO);
    check("query kernel version SYSTEM",
    load64(Interpreter_parse(interp, str_from("kernel version"))) == IntentTag.SYSTEM_INFO);
    check("query memory usage SYSTEM",
    load64(Interpreter_parse(interp, str_from("memory usage"))) == IntentTag.SYSTEM_INFO);
    check("query disk space DISK",
    load64(Interpreter_parse(interp, str_from("disk space"))) == IntentTag.DISK_USAGE);
    check("query free space DISK",
    load64(Interpreter_parse(interp, str_from("free space"))) == IntentTag.DISK_USAGE);
    check("query how full DISK",
    load64(Interpreter_parse(interp, str_from("how full is the disk"))) == IntentTag.DISK_USAGE);
    check("query running process PROC",
    load64(Interpreter_parse(interp, str_from("running processes"))) == IntentTag.SHOW_PROCESSES);
    check("query whats running PROC",
    load64(Interpreter_parse(interp, str_from("what is running"))) == IntentTag.SHOW_PROCESSES);
    check("query active process PROC",
    load64(Interpreter_parse(interp, str_from("active processes"))) == IntentTag.SHOW_PROCESSES);

    check("question what generic falls QUESTION",
    load64(Interpreter_parse(interp, str_from("what year is it"))) == IntentTag.QUESTION);
    check("question how generic falls QUESTION",
    load64(Interpreter_parse(interp, str_from("how does dns work"))) == IntentTag.QUESTION);
    check("question explain generic falls QUESTION",
    load64(Interpreter_parse(interp, str_from("explain unix sockets"))) == IntentTag.QUESTION);

    check("shell fallback raw",
    load64(Interpreter_parse(interp, str_from("foo bar baz"))) == IntentTag.SHELL_COMMAND);

    # Substring-trap immunity: "remove" must NOT route to MOVE (today's
    # input_has_word is word-prefix, not substring containment, so the
    # embedded "move" inside "remove" is invisible to the MOVE check).
    check("remove file routes to REMOVE",
    load64(Interpreter_parse(interp, str_from("remove the file foo.txt"))) == IntentTag.REMOVE);
    check("rm at token start routes to REMOVE",
    load64(Interpreter_parse(interp, str_from("rm foo.txt"))) == IntentTag.REMOVE);
    check("delete routes to REMOVE",
    load64(Interpreter_parse(interp, str_from("delete the temp dir"))) == IntentTag.REMOVE);
    check("move actual routes to MOVE",
    load64(Interpreter_parse(interp, str_from("move foo to bar"))) == IntentTag.MOVE);
    check("rename routes to MOVE",
    load64(Interpreter_parse(interp, str_from("rename foo to bar"))) == IntentTag.MOVE);
    # Plural-tolerance: "file" needle must still match "files", "process"
    # must match "processes". Word-prefix matching gives us this for free.
    check("plural files via show",
    load64(Interpreter_parse(interp, str_from("show me the files"))) == IntentTag.LIST_FILES);
    check("plural processes via state-query",
    load64(Interpreter_parse(interp, str_from("running processes"))) == IntentTag.SHOW_PROCESSES);
    check("plural directories via show",
    load64(Interpreter_parse(interp, str_from("show me the directories"))) == IntentTag.LIST_FILES);

    # Service-status NL — "is X running"/"active"/"enabled" + "status of X"
    # all map to SERVICE_CONTROL with action="status" and target=X.
    check("is X running routes to SERVICE_CONTROL",
    load64(Interpreter_parse(interp, str_from("is nginx running"))) == IntentTag.SERVICE_CONTROL);
    check("is X active routes to SERVICE_CONTROL",
    load64(Interpreter_parse(interp, str_from("is sshd active"))) == IntentTag.SERVICE_CONTROL);
    check("is X enabled routes to SERVICE_CONTROL",
    load64(Interpreter_parse(interp, str_from("is cronie enabled"))) == IntentTag.SERVICE_CONTROL);
    check("status of X routes to SERVICE_CONTROL",
    load64(Interpreter_parse(interp, str_from("status of nginx"))) == IntentTag.SERVICE_CONTROL);
    # Verify target extraction populates field2 (intent + 16).
    var svc_intent = Interpreter_parse(interp, str_from("is nginx running"));
    check("is X running extracts target",
    load64(svc_intent + 16) != 0);
    # Negative: a statement like "the application is running" must NOT
    # route to SERVICE_CONTROL (no "is " prefix).
    check("statement falls through service-query gate",
    load64(Interpreter_parse(interp, str_from("the application is running"))) != IntentTag.SERVICE_CONTROL);

    # Imperative service actions — "start nginx" / "stop sshd" / etc. all
    # map to SERVICE_CONTROL. Gated on exactly two tokens.
    check("start X routes to SERVICE_CONTROL",
    load64(Interpreter_parse(interp, str_from("start nginx"))) == IntentTag.SERVICE_CONTROL);
    check("stop X routes to SERVICE_CONTROL",
    load64(Interpreter_parse(interp, str_from("stop sshd"))) == IntentTag.SERVICE_CONTROL);
    check("restart X routes to SERVICE_CONTROL",
    load64(Interpreter_parse(interp, str_from("restart cron"))) == IntentTag.SERVICE_CONTROL);
    check("reload X routes to SERVICE_CONTROL",
    load64(Interpreter_parse(interp, str_from("reload nginx"))) == IntentTag.SERVICE_CONTROL);
    check("enable X routes to SERVICE_CONTROL",
    load64(Interpreter_parse(interp, str_from("enable cron"))) == IntentTag.SERVICE_CONTROL);
    check("disable X routes to SERVICE_CONTROL",
    load64(Interpreter_parse(interp, str_from("disable apache"))) == IntentTag.SERVICE_CONTROL);
    # Negative: multi-token NL ("start a new project") falls through —
    # the 2-token gate keeps statements from getting hijacked.
    check("start multi-word falls through",
    load64(Interpreter_parse(interp, str_from("start a new project"))) != IntentTag.SERVICE_CONTROL);
    # Negative: "enable firewall" must keep routing to FIREWALL_ENABLE via
    # parse_admin_ops (which runs before parse_service_action).
    check("enable firewall stays FIREWALL_ENABLE",
    load64(Interpreter_parse(interp, str_from("enable firewall"))) == IntentTag.FIREWALL_ENABLE);
    check("disable ufw stays FIREWALL_DISABLE",
    load64(Interpreter_parse(interp, str_from("disable ufw"))) == IntentTag.FIREWALL_DISABLE);

    # Translator coverage — slice 5: core filesystem + process + system.
    # Verifies each translate_X populates the right command name, the
    # right permission level, and (where applicable) the safety-check
    # fallback to translate_unknown when its input is unsafe or missing.

    # translate_list_files — opts pack: long+all → "-l", "-a"
    var lf_intent = Intent_new(IntentTag.LIST_FILES);
    store64(lf_intent + 8, str_from("/tmp"));
    store64(lf_intent + 40, list_options_pack(1, 1, 0, 0, 0));
    var lf_t = translate_list_files(lf_intent);
    check("translate_list_files cmd", streq(load64(lf_t), "ls") == 1);
    check("translate_list_files perm", load64(lf_t + 24) == PermissionLevel.READ_ONLY);
    check("translate_list_files args has 3", vec_len(load64(lf_t + 8)) == 3);

    # translate_show_file — happy path
    var sf_intent = Intent_new(IntentTag.SHOW_FILE);
    store64(sf_intent + 8, "/tmp/foo.txt");
    var sf_t = translate_show_file(sf_intent);
    check("translate_show_file cmd", streq(load64(sf_t), "cat") == 1);
    check("translate_show_file perm", load64(sf_t + 24) == PermissionLevel.READ_ONLY);
    # translate_show_file — unsafe path falls to translate_unknown
    var sf_bad = Intent_new(IntentTag.SHOW_FILE);
    store64(sf_bad + 8, "../etc/passwd");
    var sf_bt = translate_show_file(sf_bad);
    check("translate_show_file unsafe → unknown",
    streq(load64(sf_bt), "echo") == 1);
    # translate_show_file — null path also falls
    var sf_null = Intent_new(IntentTag.SHOW_FILE);
    var sf_nt = translate_show_file(sf_null);
    check("translate_show_file null → unknown",
    streq(load64(sf_nt), "echo") == 1);

    # translate_find_files
    var ff_intent = Intent_new(IntentTag.FIND_FILES);
    store64(ff_intent + 8, "foo.txt");
    store64(ff_intent + 16, "/tmp");
    var ff_t = translate_find_files(ff_intent);
    check("translate_find_files cmd", streq(load64(ff_t), "find") == 1);
    check("translate_find_files perm", load64(ff_t + 24) == PermissionLevel.READ_ONLY);

    # translate_search_content
    var sc_intent = Intent_new(IntentTag.SEARCH_CONTENT);
    store64(sc_intent + 8, "hello");
    store64(sc_intent + 16, "/tmp");
    var sc_t = translate_search_content(sc_intent);
    check("translate_search_content cmd", streq(load64(sc_t), "grep") == 1);
    check("translate_search_content perm", load64(sc_t + 24) == PermissionLevel.READ_ONLY);

    # translate_change_dir — happy path + null fallback
    var cd_intent = Intent_new(IntentTag.CHANGE_DIR);
    store64(cd_intent + 8, "/home");
    var cd_t = translate_change_dir(cd_intent);
    check("translate_change_dir cmd", streq(load64(cd_t), "cd") == 1);
    check("translate_change_dir perm", load64(cd_t + 24) == PermissionLevel.SAFE);
    var cd_null = Intent_new(IntentTag.CHANGE_DIR);
    var cd_nt = translate_change_dir(cd_null);
    check("translate_change_dir null → unknown",
    streq(load64(cd_nt), "echo") == 1);

    # translate_create_dir
    var mkd_intent = Intent_new(IntentTag.CREATE_DIR);
    store64(mkd_intent + 8, "/tmp/newdir");
    var mkd_t = translate_create_dir(mkd_intent);
    check("translate_create_dir cmd", streq(load64(mkd_t), "mkdir") == 1);
    check("translate_create_dir perm", load64(mkd_t + 24) == PermissionLevel.USER_WRITE);

    # translate_copy — both paths set
    var cp_intent = Intent_new(IntentTag.COPY);
    store64(cp_intent + 8, "/tmp/src");
    store64(cp_intent + 16, "/tmp/dst");
    var cp_t = translate_copy(cp_intent);
    check("translate_copy cmd", streq(load64(cp_t), "cp") == 1);
    check("translate_copy perm", load64(cp_t + 24) == PermissionLevel.USER_WRITE);
    # translate_copy — missing destination falls to unknown
    var cp_miss = Intent_new(IntentTag.COPY);
    store64(cp_miss + 8, "/tmp/src");
    var cp_mt = translate_copy(cp_miss);
    check("translate_copy missing dst → unknown",
    streq(load64(cp_mt), "echo") == 1);

    # translate_move
    var mv_intent = Intent_new(IntentTag.MOVE);
    store64(mv_intent + 8, "/tmp/from");
    store64(mv_intent + 16, "/tmp/to");
    var mv_t = translate_move(mv_intent);
    check("translate_move cmd", streq(load64(mv_t), "mv") == 1);
    check("translate_move perm", load64(mv_t + 24) == PermissionLevel.USER_WRITE);

    # translate_remove — BLOCKED permission level (caller must approve)
    var rm_intent = Intent_new(IntentTag.REMOVE);
    store64(rm_intent + 8, "/tmp/foo");
    var rm_t = translate_remove(rm_intent);
    check("translate_remove cmd", streq(load64(rm_t), "rm") == 1);
    check("translate_remove perm BLOCKED", load64(rm_t + 24) == PermissionLevel.BLOCKED);
    # translate_remove with recursive flag set
    var rm_r = Intent_new(IntentTag.REMOVE);
    store64(rm_r + 8, "/tmp/dir");
    store64(rm_r + 40, 1);
    var rm_rt = translate_remove(rm_r);
    check("translate_remove recursive args has -r and path",
    vec_len(load64(rm_rt + 8)) == 2);

    # translate_show_processes — no fields needed
    var ps_t = translate_show_processes(Intent_new(IntentTag.SHOW_PROCESSES));
    check("translate_show_processes cmd", streq(load64(ps_t), "ps") == 1);
    check("translate_show_processes perm", load64(ps_t + 24) == PermissionLevel.READ_ONLY);

    # translate_kill_process — valid pid
    var kp_intent = Intent_new(IntentTag.KILL_PROCESS);
    store64(kp_intent + 40, 1234);
    var kp_t = translate_kill_process(kp_intent);
    check("translate_kill_process cmd", streq(load64(kp_t), "kill") == 1);
    check("translate_kill_process perm ADMIN", load64(kp_t + 24) == PermissionLevel.ADMIN);
    # translate_kill_process — invalid pid (0) falls to unknown
    var kp_bad = Intent_new(IntentTag.KILL_PROCESS);
    var kp_bt = translate_kill_process(kp_bad);
    check("translate_kill_process pid=0 → unknown",
    streq(load64(kp_bt), "echo") == 1);

    # translate_system_info
    var si_t = translate_system_info(Intent_new(IntentTag.SYSTEM_INFO));
    check("translate_system_info cmd", streq(load64(si_t), "uname") == 1);
    check("translate_system_info perm", load64(si_t + 24) == PermissionLevel.READ_ONLY);

    # translate_network_info
    var ni_t = translate_network_info(Intent_new(IntentTag.NETWORK_INFO));
    check("translate_network_info cmd", streq(load64(ni_t), "ip") == 1);
    check("translate_network_info perm", load64(ni_t + 24) == PermissionLevel.READ_ONLY);

    # translate_disk_usage
    var du_t = translate_disk_usage(Intent_new(IntentTag.DISK_USAGE));
    check("translate_disk_usage cmd", streq(load64(du_t), "df") == 1);
    check("translate_disk_usage perm", load64(du_t + 24) == PermissionLevel.READ_ONLY);

    # translate_install_package — needs a packages vec at intent + 56
    var ip_intent = Intent_new(IntentTag.INSTALL_PACKAGE);
    var ip_pkgs = vec_new();
    vec_push(ip_pkgs, "vim");
    store64(ip_intent + 56, ip_pkgs);
    var ip_t = translate_install_package(ip_intent);
    check("translate_install_package cmd", streq(load64(ip_t), "apt") == 1);
    check("translate_install_package perm ADMIN", load64(ip_t + 24) == PermissionLevel.ADMIN);

    # translate_shell_command — permission derived from analyze_command_permission
    var sh_intent = Intent_new(IntentTag.SHELL_COMMAND);
    store64(sh_intent + 8, "ls");
    var sh_args = vec_new();
    store64(sh_intent + 56, sh_args);
    var sh_t = translate_shell_command(sh_intent);
    check("translate_shell_command cmd ls", streq(load64(sh_t), "ls") == 1);
    check("translate_shell_command perm READ_ONLY", load64(sh_t + 24) == PermissionLevel.READ_ONLY);
    # SHELL_COMMAND with admin command picks up ADMIN classification
    var sh_admin = Intent_new(IntentTag.SHELL_COMMAND);
    store64(sh_admin + 8, "apt");
    store64(sh_admin + 56, vec_new());
    var sh_at = translate_shell_command(sh_admin);
    check("translate_shell_command apt → ADMIN",
    load64(sh_at + 24) == PermissionLevel.ADMIN);

    # Translator coverage — slice 6: git (10 translators). All emit
    # command="git" with the operation name as the first arg. Permission
    # is READ_ONLY for status/diff/log, USER_WRITE for everything that
    # mutates the repo or remote.

    # translate_git_commit — happy path with safe message
    var gc_intent = Intent_new(IntentTag.GIT_COMMIT);
    store64(gc_intent + 8, "wip: refactor");
    var gc_t = translate_git_commit(gc_intent);
    check("translate_git_commit cmd", streq(load64(gc_t), "git") == 1);
    check("translate_git_commit perm", load64(gc_t + 24) == PermissionLevel.USER_WRITE);
    # translate_git_commit — -a flag set
    var gc_a = Intent_new(IntentTag.GIT_COMMIT);
    store64(gc_a + 8, "fix bug");
    store64(gc_a + 40, 1);
    var gc_at = translate_git_commit(gc_a);
    check("translate_git_commit -a adds flag",
    vec_len(load64(gc_at + 8)) == 4);
    # translate_git_commit — unsafe message (leading dash) falls to unknown.
    # Locks `is_safe_commit_message`'s reject-leading-dash rule that closed
    # the v1.0 security audit H7 finding (argument injection).
    var gc_bad = Intent_new(IntentTag.GIT_COMMIT);
    store64(gc_bad + 8, "-rf evil");
    var gc_bt = translate_git_commit(gc_bad);
    check("translate_git_commit leading-dash → unknown",
    streq(load64(gc_bt), "echo") == 1);

    # translate_git_diff
    var gd_intent = Intent_new(IntentTag.GIT_DIFF);
    var gd_t = translate_git_diff(gd_intent);
    check("translate_git_diff cmd", streq(load64(gd_t), "git") == 1);
    check("translate_git_diff perm READ_ONLY", load64(gd_t + 24) == PermissionLevel.READ_ONLY);
    # --staged flag
    var gd_st = Intent_new(IntentTag.GIT_DIFF);
    store64(gd_st + 40, 1);
    var gd_stt = translate_git_diff(gd_st);
    check("translate_git_diff --staged adds flag",
    vec_len(load64(gd_stt + 8)) == 2);

    # translate_git_branch
    var gb_intent = Intent_new(IntentTag.GIT_BRANCH);
    store64(gb_intent + 8, "feature-x");
    var gb_t = translate_git_branch(gb_intent);
    check("translate_git_branch cmd", streq(load64(gb_t), "git") == 1);
    check("translate_git_branch perm", load64(gb_t + 24) == PermissionLevel.USER_WRITE);
    # -d delete flag
    var gb_del = Intent_new(IntentTag.GIT_BRANCH);
    store64(gb_del + 8, "stale");
    store64(gb_del + 40, 1);
    var gb_dt = translate_git_branch(gb_del);
    check("translate_git_branch -d adds flag",
    vec_len(load64(gb_dt + 8)) == 3);

    # translate_git_status
    var gs_t = translate_git_status(Intent_new(IntentTag.GIT_STATUS));
    check("translate_git_status cmd", streq(load64(gs_t), "git") == 1);
    check("translate_git_status perm READ_ONLY", load64(gs_t + 24) == PermissionLevel.READ_ONLY);

    # translate_git_log
    var gl_t = translate_git_log(Intent_new(IntentTag.GIT_LOG));
    check("translate_git_log cmd", streq(load64(gl_t), "git") == 1);
    check("translate_git_log perm READ_ONLY", load64(gl_t + 24) == PermissionLevel.READ_ONLY);
    # log carries --oneline + -20
    check("translate_git_log args=3", vec_len(load64(gl_t + 8)) == 3);

    # translate_git_push
    var gp_t = translate_git_push(Intent_new(IntentTag.GIT_PUSH));
    check("translate_git_push cmd", streq(load64(gp_t), "git") == 1);
    check("translate_git_push perm USER_WRITE", load64(gp_t + 24) == PermissionLevel.USER_WRITE);

    # translate_git_pull
    var gpl_t = translate_git_pull(Intent_new(IntentTag.GIT_PULL));
    check("translate_git_pull cmd", streq(load64(gpl_t), "git") == 1);
    check("translate_git_pull perm USER_WRITE", load64(gpl_t + 24) == PermissionLevel.USER_WRITE);

    # translate_git_checkout
    var gco_intent = Intent_new(IntentTag.GIT_CHECKOUT);
    store64(gco_intent + 8, "main");
    var gco_t = translate_git_checkout(gco_intent);
    check("translate_git_checkout cmd", streq(load64(gco_t), "git") == 1);
    check("translate_git_checkout perm", load64(gco_t + 24) == PermissionLevel.USER_WRITE);

    # translate_git_merge
    var gm_intent = Intent_new(IntentTag.GIT_MERGE);
    store64(gm_intent + 8, "feature-x");
    var gm_t = translate_git_merge(gm_intent);
    check("translate_git_merge cmd", streq(load64(gm_t), "git") == 1);
    check("translate_git_merge perm", load64(gm_t + 24) == PermissionLevel.USER_WRITE);

    # translate_git_stash
    var gst_intent = Intent_new(IntentTag.GIT_STASH);
    store64(gst_intent + 8, "pop");
    var gst_t = translate_git_stash(gst_intent);
    check("translate_git_stash cmd", streq(load64(gst_t), "git") == 1);
    check("translate_git_stash perm", load64(gst_t + 24) == PermissionLevel.USER_WRITE);

    # Translator coverage — slice 7: user/group + firewall + remaining.
    # All admin-class operations (every user/group write, every firewall
    # mutation) land at ADMIN permission so the approval workflow gates
    # them. The two query-shape branches (firewall_list/status,
    # group_list) sit at READ_ONLY.

    # translate_user_add
    var ua_intent = Intent_new(IntentTag.USER_ADD);
    store64(ua_intent + 8, "alice");
    var ua_t = translate_user_add(ua_intent);
    check("translate_user_add cmd", streq(load64(ua_t), "useradd") == 1);
    check("translate_user_add perm ADMIN", load64(ua_t + 24) == PermissionLevel.ADMIN);

    # translate_user_delete
    var ud_intent = Intent_new(IntentTag.USER_DELETE);
    store64(ud_intent + 8, "alice");
    var ud_t = translate_user_delete(ud_intent);
    check("translate_user_delete cmd", streq(load64(ud_t), "userdel") == 1);
    check("translate_user_delete perm ADMIN", load64(ud_t + 24) == PermissionLevel.ADMIN);

    # translate_passwd
    var pw_intent = Intent_new(IntentTag.PASSWD);
    store64(pw_intent + 8, "alice");
    var pw_t = translate_passwd(pw_intent);
    check("translate_passwd cmd", streq(load64(pw_t), "passwd") == 1);
    check("translate_passwd perm ADMIN", load64(pw_t + 24) == PermissionLevel.ADMIN);

    # translate_group_add
    var ga_intent = Intent_new(IntentTag.GROUP_ADD);
    store64(ga_intent + 8, "devs");
    var ga_t = translate_group_add(ga_intent);
    check("translate_group_add cmd", streq(load64(ga_t), "groupadd") == 1);
    check("translate_group_add perm ADMIN", load64(ga_t + 24) == PermissionLevel.ADMIN);

    # translate_group_list — query, READ_ONLY
    var gli_t = translate_group_list(Intent_new(IntentTag.GROUP_LIST));
    check("translate_group_list cmd", streq(load64(gli_t), "groups") == 1);
    check("translate_group_list perm READ_ONLY", load64(gli_t + 24) == PermissionLevel.READ_ONLY);

    # translate_firewall_allow — mutating, ADMIN
    var fa_intent = Intent_new(IntentTag.FIREWALL_ALLOW);
    store64(fa_intent + 8, "8080");
    var fa_t = translate_firewall_allow(fa_intent);
    check("translate_firewall_allow cmd", streq(load64(fa_t), "ufw") == 1);
    check("translate_firewall_allow perm ADMIN", load64(fa_t + 24) == PermissionLevel.ADMIN);

    # translate_firewall_deny
    var fd_intent = Intent_new(IntentTag.FIREWALL_DENY);
    store64(fd_intent + 8, "23");
    var fd_t = translate_firewall_deny(fd_intent);
    check("translate_firewall_deny cmd", streq(load64(fd_t), "ufw") == 1);
    check("translate_firewall_deny perm ADMIN", load64(fd_t + 24) == PermissionLevel.ADMIN);

    # translate_firewall_list — query, READ_ONLY
    var fli_t = translate_firewall_list(Intent_new(IntentTag.FIREWALL_LIST));
    check("translate_firewall_list cmd", streq(load64(fli_t), "ufw") == 1);
    check("translate_firewall_list perm READ_ONLY", load64(fli_t + 24) == PermissionLevel.READ_ONLY);

    # translate_firewall_status — query, READ_ONLY
    var fst_t = translate_firewall_status(Intent_new(IntentTag.FIREWALL_STATUS));
    check("translate_firewall_status cmd", streq(load64(fst_t), "ufw") == 1);
    check("translate_firewall_status perm READ_ONLY", load64(fst_t + 24) == PermissionLevel.READ_ONLY);

    # translate_firewall_enable / disable — both ADMIN
    var fen_t = translate_firewall_enable(Intent_new(IntentTag.FIREWALL_ENABLE));
    check("translate_firewall_enable cmd", streq(load64(fen_t), "ufw") == 1);
    check("translate_firewall_enable perm ADMIN", load64(fen_t + 24) == PermissionLevel.ADMIN);
    var fdi_t = translate_firewall_disable(Intent_new(IntentTag.FIREWALL_DISABLE));
    check("translate_firewall_disable cmd", streq(load64(fdi_t), "ufw") == 1);
    check("translate_firewall_disable perm ADMIN", load64(fdi_t + 24) == PermissionLevel.ADMIN);

    # translate_firewall_delete
    var fde_intent = Intent_new(IntentTag.FIREWALL_DELETE);
    store64(fde_intent + 8, "8080");
    var fde_t = translate_firewall_delete(fde_intent);
    check("translate_firewall_delete cmd", streq(load64(fde_t), "ufw") == 1);
    check("translate_firewall_delete perm ADMIN", load64(fde_t + 24) == PermissionLevel.ADMIN);

    # translate_service_control — happy path + null-action fallback.
    # (Bare imperative parse paths cover this end-to-end in the parse-side
    # tests above; here we lock the translator's own contract.)
    var sctl_intent = Intent_new(IntentTag.SERVICE_CONTROL);
    store64(sctl_intent + 8, "start");
    store64(sctl_intent + 16, "nginx");
    var sctl_t = translate_service_control(sctl_intent);
    check("translate_service_control cmd", streq(load64(sctl_t), "systemctl") == 1);
    check("translate_service_control perm ADMIN", load64(sctl_t + 24) == PermissionLevel.ADMIN);
    var sctl_null = Intent_new(IntentTag.SERVICE_CONTROL);
    var sctl_nt = translate_service_control(sctl_null);
    check("translate_service_control null action → unknown",
    streq(load64(sctl_nt), "echo") == 1);

    # translate_audit_view + translate_agent_info — both route through
    # MCP (Translation_with_mcp). field+8 must be a Str (json_escape
    # uses str_len), matching the parser's extract_after output.
    var av_intent = Intent_new(IntentTag.AUDIT_VIEW);
    store64(av_intent + 8, str_from("agent-1"));
    var av_t = translate_audit_view(av_intent);
    check("translate_audit_view cmd echo", streq(load64(av_t), "echo") == 1);
    check("translate_audit_view perm ADMIN", load64(av_t + 24) == PermissionLevel.ADMIN);
    check("translate_audit_view mcp_tool set", load64(av_t + 40) != 0);
    # Null-field path — json_escape returns "" for null, no crash.
    var av_null = Intent_new(IntentTag.AUDIT_VIEW);
    var av_nt = translate_audit_view(av_null);
    check("translate_audit_view null field cmd echo", streq(load64(av_nt), "echo") == 1);

    var ag_intent = Intent_new(IntentTag.AGENT_INFO);
    store64(ag_intent + 8, str_from("agent-1"));
    var ag_t = translate_agent_info(ag_intent);
    check("translate_agent_info cmd echo", streq(load64(ag_t), "echo") == 1);
    check("translate_agent_info perm READ_ONLY", load64(ag_t + 24) == PermissionLevel.READ_ONLY);
    check("translate_agent_info mcp_tool set", load64(ag_t + 40) != 0);

    # translate_question + translate_unknown — both echo, both SAFE.
    var q_t = translate_question(Intent_new(IntentTag.QUESTION));
    check("translate_question cmd echo", streq(load64(q_t), "echo") == 1);
    check("translate_question perm SAFE", load64(q_t + 24) == PermissionLevel.SAFE);
    var u_t = translate_unknown(Intent_new(IntentTag.UNKNOWN));
    check("translate_unknown cmd echo", streq(load64(u_t), "echo") == 1);
    check("translate_unknown perm SAFE", load64(u_t + 24) == PermissionLevel.SAFE);

    # Slice 8 — coverage anchors for internal helpers. The script
    # `scripts/check-coverage.sh` does a fn-name grep against this file;
    # several helpers (parse_X dispatch arms, ci string ops, tokenizer,
    # mode helpers) are exercised transitively through the parse /
    # translate tests above but need a direct name reference to register.
    # Each anchor doubles as a contract check on the helper's behavior.

    # String helpers (sanitize.cyr)
    check("str_byte_at h", str_byte_at(str_from("hello"), 0) == 104);
    check("str_contains_ci hit", str_contains_ci(str_from("Hello World"), "world") == 1);
    check("str_contains_ci miss", str_contains_ci(str_from("foo"), "bar") == 0);
    check("str_find_ci hit", str_find_ci(str_from("Hello World"), "World") == 6);
    check("str_find_ci miss", str_find_ci(str_from("foo"), "bar") == (0 - 1));
    check("str_find_ci_from", str_find_ci_from(str_from("aaa bbb aaa"), "aaa", 1) == 8);
    check("str_split_ci basic", vec_len(str_split_ci(str_from("a then b"), " then ")) == 2);
    check("strip_control_chars drops",
    str_len(strip_control_chars(str_from("hi"))) == 2);
    # print_str_safe is io-side; just anchor the name via a direct call.
    print_str_safe(str_from(""));

    # str_to_int (sanitize-adjacent helper in main.cyr / commands flow)
    check("str_to_int basic", str_to_int(str_from("42")) == 42);

    # split_command_line (commands.cyr) — exercise through SHELL_COMMAND
    # fallback test which sets the args vec; here add a direct call
    # contract check.
    var scl_cmd_out[1];
    var scl_args_out = vec_new();
    var scl_argc = split_command_line(str_from("ls -la /tmp"), &scl_cmd_out, scl_args_out);
    check("split_command_line argc", scl_argc == 2);

    # Interpreter dispatch arms — parse_show_commands, parse_file_ops,
    # parse_system_ops, parse_git_ops, parse_admin_ops, parse_service_query,
    # parse_service_action, parse_state_queries all return 0 on a clearly
    # non-matching input; the anchors lock that contract.
    check("parse_show_commands no-match", parse_show_commands(str_from("xyzqq")) == 0);
    check("parse_file_ops no-match", parse_file_ops(str_from("xyzqq")) == 0);
    check("parse_system_ops no-match", parse_system_ops(str_from("xyzqq")) == 0);
    check("parse_git_ops no-match", parse_git_ops(str_from("xyzqq")) == 0);
    check("parse_admin_ops no-match", parse_admin_ops(str_from("xyzqq")) == 0);
    check("parse_service_query no-match", parse_service_query(str_from("xyzqq")) == 0);
    check("parse_service_action no-match", parse_service_action(str_from("xyzqq")) == 0);
    check("parse_state_queries no-match", parse_state_queries(str_from("xyzqq")) == 0);

    # token_count (interpreter.cyr)
    check("token_count empty", token_count(str_from("")) == 0);
    check("token_count single", token_count(str_from("foo")) == 1);
    check("token_count multi", token_count(str_from("foo bar baz")) == 3);

    # translate_core / translate_extended dispatch — both return 0 for
    # an out-of-range tag.
    check("translate_core out-of-range",
    translate_core(99, Intent_new(IntentTag.UNKNOWN)) == 0);
    check("translate_extended out-of-range",
    translate_extended(99, Intent_new(IntentTag.UNKNOWN)) == 0);

    # mode helpers
    check("mode_prompt_prefix HUMAN",
    streq(mode_prompt_prefix(Mode.HUMAN), "[HUMAN]") == 1);
    check("mode_prompt_prefix STRICT",
    streq(mode_prompt_prefix(Mode.STRICT), "[STRICT]") == 1);
    var tg_mgr = ModeManager_new(Mode.HUMAN, 1);
    var tg_r = ModeManager_toggle(tg_mgr);
    check("ModeManager_toggle ok", tg_r == 0);
    check("ModeManager_toggle changes mode",
    ModeManager_current(tg_mgr) == Mode.AI_ASSISTED);

    # Permission-classifier predicates (permissions.cyr)
    check("is_blocked_command dd", is_blocked_command("dd") == 1);
    check("is_blocked_command ls negative", is_blocked_command("ls") == 0);
    check("is_readonly_command ls", is_readonly_command("ls") == 1);
    check("is_write_command mv", is_write_command("mv") == 1);
    check("is_safe_command cd", is_safe_command("cd") == 1);

    # is_safe_arg / is_shell_metachar (sanitize.cyr)
    check("is_safe_arg clean", is_safe_arg("hello") == 1);
    check("is_safe_arg metachar", is_safe_arg("foo;bar") == 0);
    check("is_shell_metachar semi", is_shell_metachar(59) == 1);
    check("is_shell_metachar letter", is_shell_metachar(97) == 0);

    # is_word_prefix (the slice-2 helper that retired the substring trap)
    check("is_word_prefix hit", is_word_prefix(str_from("show me files"), "file") == 1);
    check("is_word_prefix no-match", is_word_prefix(str_from("show me files"), "wibble") == 0);
    check("is_word_prefix substring trap immune",
    is_word_prefix(str_from("remove the file"), "move") == 0);

    # mode_description (mode.cyr) — paired with mode_display already tested.
    check("mode_description HUMAN non-empty",
    strlen(mode_description(Mode.HUMAN)) > 0);

    # list_options_time bit (intent.cyr) — the only bit-accessor not
    # exercised by the opts-pack test above.
    var opt_t = list_options_pack(0, 0, 0, 1, 0);
    check("list_options_time on", list_options_time(opt_t) == 1);

    # build_safe_env (sanitize.cyr) — dead in the agnsh binary today
    # (no shell exec path wired in) but needed for v1.2.x interactive
    # shell. Anchor the contract: returns a non-empty env vec with PATH
    # as the first entry.
    var se_env = build_safe_env();
    check("build_safe_env non-empty", vec_len(se_env) >= 1);
    check("build_safe_env PATH first",
    streq(vec_get(se_env, 0), "PATH=/usr/bin:/bin:/usr/sbin:/sbin") == 1);

    println("");
    str_print(str_from("Passed: "));
    print_num(pass_count);
    str_print(str_from(" / "));
    print_num(pass_count + fail_count);
    println("");
    if (fail_count > 0) {
        str_print(str_from("FAILED: "));
        print_num(fail_count);
        println(" tests");
        return 1;
    }
    println("All tests passed.");
    return 0;
}
var r = main();
syscall(60, r);
