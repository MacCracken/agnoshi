# test_security.tcyr -- security regression tests

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fs.cyr"
include "lib/hashmap.cyr"
include "lib/tagged.cyr"

fn getenv(name) { return 0; }
fn ui_show_error(m) { return 0; }

include "src/sanitize.cyr"
include "src/mode.cyr"
include "src/permissions.cyr"
include "src/intent.cyr"
include "src/commands.cyr"

var pass_count = 0;
var fail_count = 0;

fn check(name, condition) {
    if (condition == 1) {
        pass_count = pass_count + 1;
    } else {
        fail_count = fail_count + 1;
        str_print(str_from("FAIL: "));
        println(name);
    }
}

fn main() {
    alloc_init();
    println("=== agnoshi security tests ===");

    check("basename simple", streq(get_command_basename("ls"), "ls"));
    check("basename absolute", streq(get_command_basename("/usr/bin/dd"), "dd"));
    check("basename relative", streq(get_command_basename("./rm"), "rm"));

    var empty = vec_new();
    check("C1 /usr/bin/dd blocked", analyze_command_permission("/usr/bin/dd", empty, 0) == PermissionLevel.BLOCKED);
    check("C1 ./chmod blocked", analyze_command_permission("./chmod", empty, 0) == PermissionLevel.BLOCKED);
    check("C1 /bin/mkfs blocked", analyze_command_permission("/bin/mkfs", empty, 0) == PermissionLevel.BLOCKED);
    check("C1 /usr/bin/apt admin", analyze_command_permission("/usr/bin/apt", empty, 0) == PermissionLevel.ADMIN);
    check("C1 /bin/ls readonly", analyze_command_permission("/bin/ls", empty, 0) == PermissionLevel.READ_ONLY);

    check("M2 valid pid", is_valid_pid(1234) == 1);
    check("M2 pid 0 invalid", is_valid_pid(0) == 0);
    check("M2 huge invalid", is_valid_pid(99999999) == 0);

    var args_rf = vec_new();
    vec_push(args_rf, "-rf");
    check("M3 -rf dangerous", rm_has_dangerous_flags(args_rf, 1) == 1);

    var args_fir = vec_new();
    vec_push(args_fir, "-fir");
    check("M3 -fir combined", rm_has_dangerous_flags(args_fir, 1) == 1);

    var args_dd = vec_new();
    vec_push(args_dd, "--");
    check("M3 -- stop flags", rm_has_dangerous_flags(args_dd, 1) == 1);

    var args_i = vec_new();
    vec_push(args_i, "-i");
    check("M3 -i safe", rm_has_dangerous_flags(args_i, 1) == 0);

    check("M4 safe abs", is_safe_path("/home/user/file") == 1);
    check("M4 traversal", is_safe_path("../../../etc/shadow") == 0);

    check("M8 invalid space", is_safe_username("test user") == 0);
    check("M8 invalid semicolon", is_safe_username("user;evil") == 0);

    check("H4 invalid space", is_safe_branch_name("my branch") == 0);

    check("H7 valid message", is_safe_commit_message("fix bug") == 1);
    check("H7 flag inject", is_safe_commit_message("-m evil") == 0);

    check("perm_ai safe", perm_ai_allowed(PermissionLevel.SAFE) == 1);
    check("perm_ai blocked", perm_ai_allowed(PermissionLevel.BLOCKED) == 0);
    check("perm_req sys", perm_requires_approval(PermissionLevel.SYSTEM_WRITE) == 1);
    check("perm_req safe", perm_requires_approval(PermissionLevel.SAFE) == 0);

    println("");
    str_print(str_from("Passed: "));
    print_num(pass_count);
    str_print(str_from(" / "));
    print_num(pass_count + fail_count);
    println("");
    if (fail_count > 0) {
        str_print(str_from("FAILED: "));
        print_num(fail_count);
        println(" tests");
        return 1;
    }
    println("All security tests passed.");
    return 0;
}
var r = main();
syscall(60, r);
