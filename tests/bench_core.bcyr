# bench_core.bcyr -- agnoshi core benchmarks

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fs.cyr"
include "lib/hashmap.cyr"
include "lib/tagged.cyr"
include "lib/fnptr.cyr"
include "lib/bench.cyr"

fn getenv(name) { return 0; }
fn ui_show_error(m) { return 0; }
fn ui_show_warning(m) { return 0; }
fn chrono_now_rfc3339() { return "2026-01-01T00:00:00Z"; }

include "src/sanitize.cyr"
include "src/mode.cyr"
include "src/permissions.cyr"
include "src/intent.cyr"
include "src/commands.cyr"
include "src/translate.cyr"
include "src/interpreter.cyr"

var _interp = 0;

fn work_parse_list() { Interpreter_parse(_interp, "show me all files"); return 0; }
fn work_parse_cd() { Interpreter_parse(_interp, "go to /home"); return 0; }
fn work_parse_find() { Interpreter_parse(_interp, "find files named foo"); return 0; }
fn work_parse_git() { Interpreter_parse(_interp, "git status"); return 0; }
fn work_parse_shell() { Interpreter_parse(_interp, "ls -la /tmp"); return 0; }

fn work_translate_list() {
    var intent = Intent_new(IntentTag.LIST_FILES);
    store64(intent + 40, 3);
    Interpreter_translate(_interp, intent);
    return 0;
}

fn work_translate_cd() {
    var intent = Intent_new(IntentTag.CHANGE_DIR);
    store64(intent + 8, "/home");
    Interpreter_translate(_interp, intent);
    return 0;
}

fn work_perm() {
    var e = vec_new();
    analyze_command_permission("ls", e, 0);
    analyze_command_permission("/usr/bin/dd", e, 0);
    analyze_command_permission("apt", e, 0);
    analyze_command_permission("cp", e, 0);
    analyze_command_permission("cd", e, 0);
    return 0;
}

fn work_basename() {
    get_command_basename("/usr/bin/dd");
    get_command_basename("./rm");
    get_command_basename("ls");
    return 0;
}

fn work_safe_path() {
    is_safe_path("/home/user/file.txt");
    is_safe_path("../../../etc/shadow");
    is_safe_arg("hello world");
    return 0;
}

var N = 10000;

fn main() {
    alloc_init();
    println("starting");
    _interp = Interpreter_new();
    println("interp created");
    var all = vec_new();
    println("testing str_contains_ci...");
    var r1 = str_contains_ci("hello world", "world");
    println("str_contains_ci works");
    println("testing Intent_new...");
    var i1 = Intent_new(IntentTag.UNKNOWN);
    println("Intent_new works");
    println("testing Interpreter_parse...");
    var res = Interpreter_parse(_interp, "hello");
    println("parse empty works");
    res = Interpreter_parse(_interp, "show me all files");
    println("parse works");
    work_translate_list();
    println("translate works");
    work_perm();
    println("perm works");

    var b1 = bench_new("parse/list_files");
    bench_run(b1, &work_parse_list, N);
    vec_push(all, b1);

    var b2 = bench_new("parse/cd");
    bench_run(b2, &work_parse_cd, N);
    vec_push(all, b2);

    var b3 = bench_new("parse/find_files");
    bench_run(b3, &work_parse_find, N);
    vec_push(all, b3);

    var b4 = bench_new("parse/git_status");
    bench_run(b4, &work_parse_git, N);
    vec_push(all, b4);

    var b5 = bench_new("parse/shell_cmd");
    bench_run(b5, &work_parse_shell, N);
    vec_push(all, b5);

    var b6 = bench_new("translate/list_files");
    bench_run(b6, &work_translate_list, N);
    vec_push(all, b6);

    var b7 = bench_new("translate/cd");
    bench_run(b7, &work_translate_cd, N);
    vec_push(all, b7);

    var b8 = bench_new("perm/classify_5");
    bench_run(b8, &work_perm, N);
    vec_push(all, b8);

    var b9 = bench_new("sanitize/basename");
    bench_run(b9, &work_basename, N);
    vec_push(all, b9);

    var b10 = bench_new("sanitize/safe_path");
    bench_run(b10, &work_safe_path, N);
    vec_push(all, b10);

    bench_report_all(all);
    return 0;
}
var r = main();
syscall(60, r);
