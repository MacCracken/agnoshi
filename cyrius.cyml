[package]
name = "agnoshi"
version = "${file:VERSION}"
description = "AI-native natural language shell for AGNOS"
license = "GPL-3.0-only"
language = "cyrius"
cyrius = "6.0.87"
repository = "https://github.com/MacCracken/agnoshi"

[build]
entry = "src/agnsh.cyr"
output = "agnsh"

[deps]
stdlib = ["string", "fmt", "alloc", "vec", "str", "syscalls", "io", "fs", "json", "chrono", "hashmap", "args", "tagged", "process", "fnptr", "net", "sakshi", "assert", "bench"]
