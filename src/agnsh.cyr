# agnsh.cyr -- minimal working agnoshi binary for v1.0
# Demonstrates the core NL -> command translation pipeline.
# Uses only Cyrius stdlib features that actually work.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/fs.cyr"
include "lib/hashmap.cyr"
include "lib/tagged.cyr"
include "lib/args.cyr"
include "lib/chrono.cyr"
# process.cyr → process_agnos.cyr under CYRIUS_TARGET_AGNOS (sys_spawn/waitpid
# today; swaps onto the 1.43.x execwait syscall later). Pulled in so the `run`
# builtin's live path compiles now and un-gates with a one-line flag flip.
include "lib/process.cyr"

# `ui_show_*` are minimal stand-ins because src/ui.cyr isn't pulled
# into this entry's include graph yet (queued for the v1.2.1
# interactive-shell wire-up). `chrono_now_rfc3339` now reaches into
# lib/chrono.cyr's iso8601_now (real wall-clock time) instead of the
# v1.0-era fixed-string stub; the wrap converts iso8601_now's cstring
# buffer to a Str so audit's json_escape (Str-typed) reads a valid
# length header.
fn ui_show_error(m) { return 0; }
fn ui_show_warning(m) { return 0; }
fn chrono_now_rfc3339() { return str_from(iso8601_now()); }

include "src/sanitize.cyr"
include "src/mode.cyr"
include "src/permissions.cyr"
include "src/intent.cyr"
include "src/commands.cyr"
include "src/verbs.cyr"
include "src/translate.cyr"
include "src/interpreter.cyr"
include "src/approval.cyr"
include "src/audit.cyr"
include "src/history.cyr"

var VERSION_STR = "agnoshi 1.4.3";

fn print_version() {
    println(VERSION_STR);
}

fn print_usage() {
    println("Usage: agnsh [OPTIONS] [-c COMMAND]");
    println("");
    println("  -c, --command CMD   Execute one command and exit");
    println("  -v, --version       Show version");
    println("  -h, --help          Show this help");
    println("");
    println("Interactive mode (no args): type natural language or shell commands.");
    println("  help                -- builtin, file, and run commands");
    println("  ls cat cp mv rm ... -- in-process file verbs");
    println("  run PATH            -- run a program from disk (pending agnos 1.43.x)");
    println("  exit                -- leave shell");
}

fn history_path() {
    # Mirrors audit_log_path's shape — cstring with manual concat so
    # file_exists/read/write can use it directly. `$HOME/.agnsh_history`
    # matches the docs/agnsh.1 convention.
    #
    # On agnos there is no /proc/self/environ and the ring-3 init stack passes
    # envp=NULL, so getenv("HOME") can only ever return 0 here — calling it is
    # pure dead weight that also reserves an 8 KB stack buffer (cyrius getenv)
    # co-resident with interactive_loop's 4 KB read buffer. Until the 1.41.12
    # kernel stack-relocation that combo overflowed the 12 KB ring-3 stack and
    # faulted agnsh right after its banner. Skip getenv on agnos and return the
    # fixed /tmp path directly; the host build keeps the $HOME behavior its
    # smoke tests assert.
    #ifdef CYRIUS_TARGET_AGNOS
    return "/tmp/agnsh_history";
    #endif
    var home = getenv("HOME");
    if (home == 0) { return "/tmp/agnsh_history"; }
    var hlen = strlen(home);
    var suffix = "/.agnsh_history";
    var slen = strlen(suffix);
    var buf = alloc(hlen + slen + 1);
    memcpy(buf, home, hlen);
    memcpy(buf + hlen, suffix, slen);
    store8(buf + hlen + slen, 0);
    return buf;
}
fn audit_log_path() {
    # `$HOME/.agnsh_audit.log` is the v1.0 convention (per docs/agnsh.1).
    # Returns a NULL-TERMINATED cstring (not a Str) because AuditLogger_log
    # passes the path to syscall(SYS_OPEN) directly, and str_cat allocates
    # a length-prefixed buffer with no trailing zero. Falls back to /tmp
    # when HOME is unset (test harness / restricted envs).
    #
    # Same agnos rationale as history_path: getenv is a guaranteed-0 no-op on
    # agnos and its 8 KB stack buffer is a deep-stack hazard, so skip it there.
    #ifdef CYRIUS_TARGET_AGNOS
    return "/tmp/agnsh_audit.log";
    #endif
    var home = getenv("HOME");
    if (home == 0) { return "/tmp/agnsh_audit.log"; }
    var hlen = strlen(home);
    var suffix = "/.agnsh_audit.log";
    var slen = strlen(suffix);
    var buf = alloc(hlen + slen + 1);
    memcpy(buf, home, hlen);
    memcpy(buf + hlen, suffix, slen);
    store8(buf + hlen + slen, 0);
    return buf;
}
fn classify_audit_result(tag, perm, desc_cstr) {
    # Maps the parse+translate outcome to one of six audit-result
    # labels. Mirrors slice 8's user-facing Hint: lines so a downstream
    # `jq 'select(.result == "rejected_safety")'` can find exactly the
    # same input shapes the user saw a Hint for. Order matters:
    # safety-rejected, needs_llm, and needs_exec are tag/description
    # properties that supersede the permission-derived classification.
    #
    #   rejected_safety  -- translator's safety check rejected (path
    #                       traversal, shell metachars, leading-dash
    #                       commit msg, null pid, etc.). Detected by
    #                       translate_unknown's "Unknown intent" stamp.
    #   needs_llm        -- QUESTION intent: parser routed to LLM but
    #                       streaming isn't wired yet.
    #   needs_exec       -- PIPELINE intent: no translator arm yet.
    #   blocked          -- BLOCKED permission: caller-must-approve.
    #   needs_approval   -- HIGH risk (ADMIN / SYSTEM_WRITE): runnable
    #                       only after an interactive approval prompt
    #                       (interactive-shell exec wire-up).
    #   proposed         -- SAFE / READ_ONLY / USER_WRITE: auto-runnable
    #                       once exec lands; logged as-is today.
    # QUESTION and PIPELINE tags first — PIPELINE has no translator
    # arm (`translate_extended` doesn't handle 41) so the dispatch
    # falls through to translate_unknown, stamping the same "Unknown
    # intent" description as a real safety-rejected translation.
    # Without the tag-first order PIPELINE would mis-classify as
    # rejected_safety.
    if (tag == IntentTag.QUESTION) { return "needs_llm"; }
    if (tag == IntentTag.PIPELINE) { return "needs_exec"; }
    if (streq(desc_cstr, "Unknown intent") == 1) { return "rejected_safety"; }
    if (perm == PermissionLevel.BLOCKED) { return "blocked"; }
    if (risk_from_permission(perm) == RiskLevel.HIGH) { return "needs_approval"; }
    return "proposed";
}
fn audit_one_shot(input_cstr, cmd_cstr, perm, mode_label_cstr, tag, desc_cstr) {
    # Every -c invocation produces one audit line. `approved` is 1 for
    # auto-runnable (SAFE/READ_ONLY/USER_WRITE), 0 for anything that
    # would require an interactive approval prompt (SYSTEM_WRITE/ADMIN)
    # or is outright blocked. `result` carries the slice-9 audit-result
    # vocabulary (see classify_audit_result). When the exec wire-up
    # lands, "proposed" will be replaced by "executed" / "denied" /
    # "error" at the exec call site; the other five labels stay.
    var approved = 0;
    if (perm == PermissionLevel.SAFE) { approved = 1; }
    elif (perm == PermissionLevel.READ_ONLY) { approved = 1; }
    elif (perm == PermissionLevel.USER_WRITE) { approved = 1; }
    var result_label = classify_audit_result(tag, perm, desc_cstr);
    var entry = AuditEntry_new(
    str_from("user"),
    str_from(mode_label_cstr),
    str_from(input_cstr),
    str_from(cmd_cstr),
    approved,
    str_from(result_label)
    );
    var logger = AuditLogger_new(audit_log_path());
    AuditLogger_log(logger, entry);
}
fn print_intent_result(input_cstr, mode_label_cstr) {
    var s = str_from(input_cstr);
    var interp = Interpreter_new();
    var intent = Interpreter_parse(interp, s);
    var tag = load64(intent);

    str_print(str_from("Intent: "));
    str_print(str_from_int(tag));

    if (tag == IntentTag.UNKNOWN) {
        println(" (UNKNOWN)");
        return 0;
    }

    var translation = Interpreter_translate(interp, intent);
    if (translation == 0) {
        println(" (no translation)");
        return 0;
    }

    var cmd = load64(translation);
    var perm = load64(translation + 24);
    var risk = risk_from_permission(perm);

    # `cmd` is a cstring literal stored by translate_X (e.g. "ls", "cp",
    # "systemctl"); wrap in str_from so str_print's `load64(s+8)` reads a
    # real Str length, not the bytes past the cstring's null terminator.
    # Pre-v1.2.1 the line silently printed garbage / nothing.
    str_print(str_from("  Command: "));
    str_print(str_from(cmd));
    println("");

    str_print(str_from("  Risk: "));
    println(risk_icon(risk));

    # BLOCKED commands (Risk: CRITICAL) cannot be auto-executed —
    # surface this in `-c` output so scripts and call-sites can see the
    # decision without parsing a permission integer.
    if (perm == PermissionLevel.BLOCKED) {
        println("  WARNING: BLOCKED -- would not execute without explicit override");
    } elif (risk == RiskLevel.HIGH) {
        println("  Approval required (interactive prompt in shell mode)");
    }

    # Error-recovery hints. Three "parse succeeded but translation isn't
    # actually runnable" classes — without a hint the user sees
    # `Command: echo / Risk: [LOW]` and reasonably believes their input
    # ran. Surface what actually happened so they can rephrase.
    #
    # 1. QUESTION (tag 42) — LLM-routed; streaming not wired yet.
    # 2. PIPELINE (tag 41) — no translate_pipeline arm; falls to
    #    translate_unknown. Pipeline auto-exec arrives with the exec
    #    wire-up.
    # 3. Safety-rejected translation — any tag whose translate_X called
    #    is_safe_path_str / is_safe_arg_str on a parser-extracted field
    #    and rejected (path traversal, shell metachars, leading dash,
    #    null PID, etc.). Detected by the "Unknown intent" description
    #    that translate_unknown stamps. Surfacing this is the actual
    #    v1.2.1 "error recovery loop" sub-bullet: tell the user the
    #    translator refused so they can rephrase.
    if (tag == IntentTag.QUESTION) {
        println("  Hint: question intent -- LLM streaming arrives in a later slice");
    } elif (tag == IntentTag.PIPELINE) {
        println("  Hint: pipeline intent -- auto-exec arrives with the exec wire-up");
    } elif (streq(load64(translation + 16), "Unknown intent") == 1) {
        println("  Hint: translator safety check rejected this input -- try rephrasing");
    }

    audit_one_shot(input_cstr, cmd, perm, mode_label_cstr, tag, load64(translation + 16));
    return 0;
}

# Line-splitting read buffer (module-static so the leftover survives between
# calls). Module-scope `var X[N]` allocates N*u64 = 8N bytes, so [512] = 4096 B.
var rl_buf[512];
var rl_len = 0;   # bytes currently held in rl_buf
var rl_pos = 0;   # read cursor into rl_buf

fn read_line(buf, maxlen) {
    # Return exactly ONE line from stdin, buffering any leftover for the next
    # call. This is target-agnostic and the reason we don't just `read()` once:
    #   - On agnos the kernel's read(fd=0) is line-disciplined (canonical-lite,
    #     1.41.15): it blocks until Enter, echoes + handles backspace as you
    #     type, and returns ONE line with its trailing newline — so rl_buf holds
    #     exactly that line and drains empty each call. (The old per-byte read
    #     masked IRQ1 in the ring-3 IF=0 gap between syscalls and dropped
    #     shift-release breaks — the 1.41.14 "Command: D" stuck-shift collapse;
    #     the kernel now owns echo + line discipline, so we never echo here.)
    #   - On the host (Linux pipe) read() returns a MULTI-line blob in one go; a
    #     naive single read would swallow several user lines into one buffer and
    #     break line-oriented dispatch (streq against builtins, etc.). The carry
    #     buffer hands those back one line at a time.
    # Returns the line length excluding the newline, 0 for an empty line (bare
    # Enter), -1 on EOF before any data.
    var i = 0;
    while (1 == 1) {
        if (rl_pos >= rl_len) {                 # carry buffer empty -> refill
            rl_pos = 0;
            rl_len = syscall(SYS_READ, 0, &rl_buf, 4095);
            if (rl_len <= 0) {
                if (i == 0) { return 0 - 1; }   # EOF, nothing accumulated
                break;                          # EOF after a newline-less tail
            }
        }
        while (rl_pos < rl_len) {
            var ch = load8(&rl_buf + rl_pos);
            rl_pos = rl_pos + 1;
            if (ch == 10) {                     # line terminator: done
                store8(buf + i, 0);
                return i;
            }
            if (i < maxlen - 1) {
                store8(buf + i, ch);
                i = i + 1;
            }
        }
        # buffer drained with no newline -> loop refills and keeps accumulating
    }
    store8(buf + i, 0);
    return i;
}
fn try_mode_switch(mgr, arg_cstr) {
    # Maps a CLI mode name to the enum and switches the ModeManager.
    # Returns 1 on success, 0 on unknown name. Names match the four
    # `mode_display` labels lowercased (auto / assist / human / strict).
    if (streq(arg_cstr, "auto") == 1) {
        ModeManager_switch(mgr, Mode.AI_AUTONOMOUS);
        return 1;
    }
    if (streq(arg_cstr, "assist") == 1) {
        ModeManager_switch(mgr, Mode.AI_ASSISTED);
        return 1;
    }
    if (streq(arg_cstr, "human") == 1) {
        ModeManager_switch(mgr, Mode.HUMAN);
        return 1;
    }
    if (streq(arg_cstr, "strict") == 1) {
        ModeManager_switch(mgr, Mode.STRICT);
        return 1;
    }
    return 0;
}

# RUN_EXECWAIT_READY gates the `run` builtin's live exec path. It stays 0 until
# agnos ships the execwait syscall (the 1.43.x arc). Until then `run` validates
# its argument and refuses cleanly instead of driving the spawn(#3)+waitpid(#4)
# path, which fatally faults on this kernel:
#   - waitpid(#4) busy-waits on a bare `hlt` while IF=0 (ring-3 syscalls run
#     interrupts-masked) → the timer ISR that drives the scheduler never fires,
#     the child never runs/exits, the box HARD-HANGS;
#   - spawn(#3) → the in-memory elf_load does a CR3-switch memcpy of agnsh's
#     mmap-arena buffer, which the child CR3 leaves unmapped → #PF/#DF/triple
#     fault; and its 4 KB page mapped as a 2 MB huge page aliases live memory.
# The proven exec path is the in-kernel recovery shell's elf_load_from_file +
# synchronous exec_and_wait. 1.43.x exposes that as a ring-3 execwait syscall
# and process_agnos.cyr's run() swaps onto it; THEN this flag flips to 1 and the
# builtin below goes live with no other agnsh-side change. Order matters: do not
# flip until both the kernel syscall and the process_agnos run() swap have landed.
var RUN_EXECWAIT_READY = 0;

# Run a program from disk. Shared by the interactive loop and the -c one-shot
# path. `path` is an already-validated absolute cstr. Returns the child exit
# code, or 1 on refusal/abort/launch-failure.
fn sh_run_program(path, mode) {
    if (RUN_EXECWAIT_READY == 0) {
        println("run: external programs not yet available (pending agnos 1.43.x execwait)");
        return 1;
    }
    # Launching an arbitrary on-disk binary is at least as consequential as a
    # destructive file verb, so it takes the same FIX 4 mode gate: HUMAN/STRICT
    # confirm before launch; AUTO/ASSIST run directly.
    if (mode_needs_confirm(mode) == 1) {
        # verb_confirm prints "(aborted)" itself on a no/Enter, matching the
        # rm/mv convention — stay silent here rather than double-reporting.
        if (verb_confirm(str_cat3_cstr("run ", path, "")) == 0) { return 1; }
    }
    var r = run(path, 0, 0);
    if (is_ok(r) == 1) {
        var code = result_unwrap(r);
        if (code != 0) {
            str_print(str_from("run: exit "));
            str_print(str_from_int(code));
            println("");
        }
        return code;
    }
    println("run: failed to launch program");
    return 1;
}

fn interactive_loop() {
    println(VERSION_STR);
    println("AI-native shell -- type a natural-language command, or 'exit' to quit.");
    println("Built-ins: help, version, mode, history, clear, exit");
    println("Files: ls cat cp mv rm mkdir rmdir touch echo wc find grep   Run: run");
    println("");

    var buf[4096];
    var interp = Interpreter_new();
    # ShellConfig_default sets Mode.AI_ASSISTED — same starting point
    # as the v1.0 design intent. ModeManager owns the "allow_switching"
    # bit; 1 means the user can change modes at runtime.
    var mode_mgr = ModeManager_new(Mode.AI_ASSISTED, 1);
    # CommandHistory keeps the last 1000 lines (ShellConfig default is
    # 10000 but that's heavy for interactive; 1000 covers a long session
    # without bloating the on-disk file). Loads from $HOME/.agnsh_history
    # if present, so history survives across sessions.
    var history = CommandHistory_new(history_path(), 1000);

    while (1 == 1) {
        # Prompt carries the current mode prefix so the user always
        # knows the AI-autonomy level before typing. Pre-v1.2.1 the
        # prompt was a bare `> ` regardless of mode.
        var cur_mode = ModeManager_current(mode_mgr);
        str_print(str_from(mode_prompt_prefix(cur_mode)));
        str_print(str_from(" > "));
        var n = read_line(&buf, 4096);
        if (n < 0) { break; }
        if (n == 0) { continue; }

        if (streq(&buf, "exit") == 1) { break; }
        if (streq(&buf, "quit") == 1) { break; }
        if (streq(&buf, "history") == 1) {
            var recent = CommandHistory_get_recent(history, 20);
            var rcount = vec_len(recent);
            if (rcount == 0) {
                println("(history empty)");
            } else {
                for (var i = 0; i < rcount; i = i + 1) {
                    str_print(str_from("  "));
                    str_print(str_from_int(i + 1));
                    str_print(str_from("  "));
                    str_print(vec_get(recent, i));
                    println("");
                }
            }
            continue;
        }
        if (streq(&buf, "help") == 1) {
            println("Built-ins:");
            println("  help                                 show this help");
            println("  version                              show version");
            println("  mode                                 show current mode");
            println("  mode auto|assist|human|strict        switch mode");
            println("  history                              show last 20 commands");
            println("  clear                                clear screen");
            println("  exit, quit                           leave shell (saves history)");
            println("Files:");
            println("  ls [PATH]                            list directory entries");
            println("  cat FILE                             print file contents");
            println("  cp SRC DST                           copy a file");
            println("  mv SRC DST                           move/rename a file");
            println("  rm FILE                              remove a file");
            println("  mkdir DIR                            create a directory");
            println("  rmdir DIR                            remove an empty directory");
            println("  touch FILE                           create/update a file");
            println("  echo TEXT [> FILE]                   print TEXT (> writes to FILE)");
            println("  wc FILE                              count lines/words/bytes");
            println("  find PATH [-name PAT]                find entries by name");
            println("  grep PATTERN FILE                    search FILE for PATTERN");
            println("Run:");
            println("  run PATH                             run a program from disk");
            println("                                       (pending agnos 1.43.x)");
            println("Or type a natural-language command.");
            continue;
        }
        if (streq(&buf, "version") == 1) {
            print_version();
            continue;
        }
        if (streq(&buf, "clear") == 1) {
            # ANSI ED + CUP — clear screen + cursor to home (0,0).
            str_print(str_from("\x1b[2J\x1b[H"));
            continue;
        }
        if (streq(&buf, "mode") == 1) {
            str_print(str_from("Current mode: "));
            str_print(str_from(mode_display(cur_mode)));
            println("");
            println("Available: auto, assist, human, strict");
            continue;
        }
        if (cstr_starts_with(&buf, "mode ") == 1) {
            var arg = &buf + 5;
            if (try_mode_switch(mode_mgr, arg) == 1) {
                str_print(str_from("Mode -> "));
                str_print(str_from(mode_display(ModeManager_current(mode_mgr))));
                println("");
            } else {
                str_print(str_from("Unknown mode: "));
                println(arg);
                println("Available: auto, assist, human, strict");
            }
            continue;
        }

        # `run PATH` — launch a program from disk. A first-class builtin (NOT an
        # FS verb), dispatched before dispatch_fs_verb so `run` is never mistaken
        # for a filesystem op. Validates the path here; sh_run_program owns the
        # mode gate + the kernel-gated exec (see RUN_EXECWAIT_READY).
        if (streq(&buf, "run") == 1) {
            println("usage: run /abs/path/to/program");
            continue;
        }
        if (cstr_starts_with(&buf, "run ") == 1) {
            var rpath = &buf + 4;
            while (load8(rpath) == 32) { rpath = rpath + 1; }
            if (load8(rpath) == 0) {
                println("usage: run /abs/path/to/program");
                continue;
            }
            if (load8(rpath) != 47) {
                println("run: path must be absolute (start with /)");
                continue;
            }
            if (is_safe_path(rpath) == 0) {
                println("run: unsafe path (traversal or shell metacharacter)");
                continue;
            }
            sh_run_program(rpath, cur_mode);
            CommandHistory_add(history, &buf);
            continue;
        }

        # FS-verb dispatch (Track B, 1.4.2). If the line's first word is one
        # of the core filesystem verbs (ls/cat/cp/mv/rm/mkdir/rmdir/touch/
        # echo/wc/find/grep), run it IN-PROCESS via the agnos syscalls and
        # skip the NL→intent path entirely. These are builtins (not external
        # binaries) because launching a standalone binary waits on ring-3
        # execwait, a future 1.43.x kernel feature; until then the verbs must
        # execute via syscalls inside the shell process. dispatch_fs_verb
        # returns -1 when the first word is NOT an FS verb (fall through to
        # the NL path); otherwise it runs the verb and returns its exit code.
        # `cur_mode` (the current ModeManager mode) is threaded in so
        # destructive verbs (rm/mv/cp-overwrite) apply the FIX 4 mode-gated
        # confirm: HUMAN/STRICT prompt inline, AUTO/ASSIST run directly.
        if (dispatch_fs_verb(&buf, cur_mode) >= 0) {
            # Verbs are real commands the user typed — record them in history.
            CommandHistory_add(history, &buf);
            continue;
        }

        # Record every non-builtin input in history. Persists on exit.
        CommandHistory_add(history, &buf);

        # Audit entry carries the actual session mode (vs `-c`'s
        # hardcoded "auto"); a downstream filter on `"mode":"HUMAN"`
        # can now distinguish interactive-human sessions from
        # interactive-auto.
        print_intent_result(&buf, mode_display(cur_mode));
    }
    CommandHistory_save(history);
    println("bye");
    return 0;
}

fn main() {
    alloc_init();
    args_init();

    var n_args = argc();
    if (n_args < 2) {
        return interactive_loop();
    }

    var arg1 = argv(1);
    if (streq(arg1, "-v") == 1 || streq(arg1, "--version") == 1) {
        print_version();
        return 0;
    }
    if (streq(arg1, "-h") == 1 || streq(arg1, "--help") == 1) {
        print_usage();
        return 0;
    }
    # Optional `--mode NAME` prefix before -c. Lets the one-shot path drive
    # the FIX 4 mode-gated confirm non-interactively (and host smoke tests
    # pipe y/n under a chosen mode). Default for -c stays AUTO — destructive
    # verbs run directly, matching the prior `-c` behavior. When present,
    # shift the -c / command positionals two slots to the right.
    var c_mode = Mode.AI_AUTONOMOUS;
    var c_idx = 1;     # index of the -c flag
    if (streq(arg1, "--mode") == 1) {
        if (n_args < 3) {
            println("Error: --mode requires a name (auto|assist|human|strict)");
            return 1;
        }
        c_mode = mode_from_name(argv(2), Mode.AI_AUTONOMOUS);
        c_idx = 3;
        arg1 = argv(3);
    }
    if (streq(arg1, "-c") == 1 || streq(arg1, "--command") == 1) {
        if (n_args < c_idx + 2) {
            println("Error: -c requires a command argument");
            return 1;
        }
        var c_cmd = argv(c_idx + 1);
        # FS verbs run in-process even in one-shot mode (`agnsh -c "ls /tmp"`).
        # dispatch_fs_verb returns the verb's exit code (>=0) when the first
        # word is an FS verb, else -1 to fall through to the NL→intent path.
        # `c_mode` carries the optional --mode (default AUTO) so destructive
        # verbs apply the FIX 4 confirm.
        var vrc = dispatch_fs_verb(c_cmd, c_mode);
        if (vrc >= 0) { return vrc; }
        # `run PATH` in one-shot mode (`agnsh -c "run /bin/klug"`). Same
        # validation + kernel gate as the interactive path.
        if (streq(c_cmd, "run") == 1) { println("usage: run /abs/path/to/program"); return 1; }
        if (cstr_starts_with(c_cmd, "run ") == 1) {
            var rpath = c_cmd + 4;
            while (load8(rpath) == 32) { rpath = rpath + 1; }
            if (load8(rpath) == 0) { println("usage: run /abs/path/to/program"); return 1; }
            if (load8(rpath) != 47) { println("run: path must be absolute (start with /)"); return 1; }
            if (is_safe_path(rpath) == 0) { println("run: unsafe path (traversal or shell metacharacter)"); return 1; }
            return sh_run_program(rpath, c_mode);
        }
        # -c is one-shot non-interactive; the audit `mode` field reflects the
        # resolved mode label (was hardcoded "auto"; --mode now selects).
        print_intent_result(c_cmd, mode_display(c_mode));
        return 0;
    }

    print_usage();
    return 1;
}

var exit_code = main();
syscall(60, exit_code);
