// translate.cyr — Intent -> shell command translation
//
// Each translate_* function converts an Intent into a Translation
// with command, args, description, and permission level.

// --- Filesystem translators ---

fn translate_list_files(intent) {
    var args = vec_new();
    var opts = intent.int1;
    if (list_options_long(opts) == 1) { vec_push(args, "-l"); }
    if (list_options_all(opts) == 1) { vec_push(args, "-a"); }
    if (list_options_human(opts) == 1) { vec_push(args, "-h"); }
    if (list_options_time(opts) == 1) { vec_push(args, "-t"); }
    if (list_options_recursive(opts) == 1) { vec_push(args, "-R"); }
    if (intent.field1 != 0) { vec_push(args, intent.field1); }
    return Translation_new("ls", args, "List files and directories", PermissionLevel.READ_ONLY, "ls shows directory contents");
}

fn translate_show_file(intent) {
    var args = vec_new();
    vec_push(args, intent.field1);
    return Translation_new("cat", args, "Display file contents", PermissionLevel.READ_ONLY, "cat outputs file contents to stdout");
}

fn translate_find_files(intent) {
    var args = vec_new();
    if (intent.field2 != 0) {
        vec_push(args, intent.field2);
    } else {
        vec_push(args, ".");
    }
    vec_push(args, "-name");
    if (intent.field1 != 0) {
        vec_push(args, intent.field1);
    } else {
        vec_push(args, "*");
    }
    return Translation_new("find", args, "Search for files by name", PermissionLevel.READ_ONLY, "find searches directory trees for matching files");
}

fn translate_search_content(intent) {
    var args = vec_new();
    vec_push(args, "-r");
    if (intent.field1 != 0) { vec_push(args, intent.field1); }
    if (intent.field2 != 0) { vec_push(args, intent.field2); }
    return Translation_new("grep", args, "Search file contents", PermissionLevel.READ_ONLY, "grep searches for text patterns in files");
}

fn translate_change_dir(intent) {
    var args = vec_new();
    vec_push(args, intent.field1);
    return Translation_new("cd", args, "Change directory", PermissionLevel.SAFE, "cd changes the current working directory");
}

fn translate_create_dir(intent) {
    var args = vec_new();
    vec_push(args, "-p");
    vec_push(args, intent.field1);
    return Translation_new("mkdir", args, "Create directory", PermissionLevel.USER_WRITE, "mkdir creates new directories");
}

fn translate_copy(intent) {
    var args = vec_new();
    if (intent.field1 != 0) { vec_push(args, intent.field1); }
    if (intent.field2 != 0) { vec_push(args, intent.field2); }
    return Translation_new("cp", args, "Copy files", PermissionLevel.USER_WRITE, "cp copies files and directories");
}

fn translate_move(intent) {
    var args = vec_new();
    if (intent.field1 != 0) { vec_push(args, intent.field1); }
    if (intent.field2 != 0) { vec_push(args, intent.field2); }
    return Translation_new("mv", args, "Move/rename files", PermissionLevel.USER_WRITE, "mv moves or renames files and directories");
}

fn translate_remove(intent) {
    var args = vec_new();
    if (intent.int1 == 1) { vec_push(args, "-r"); }
    vec_push(args, intent.field1);
    return Translation_new("rm", args, "Remove files", PermissionLevel.BLOCKED, "rm permanently deletes files — use with caution");
}

fn translate_show_processes(intent) {
    var args = vec_new();
    vec_push(args, "aux");
    return Translation_new("ps", args, "Show running processes", PermissionLevel.READ_ONLY, "ps shows process information");
}

fn translate_kill_process(intent) {
    var args = vec_new();
    vec_push(args, fmt_int(intent.int1));
    return Translation_new("kill", args, "Terminate a process", PermissionLevel.ADMIN, "kill sends a signal to terminate a process");
}

fn translate_system_info(intent) {
    var args = vec_new();
    vec_push(args, "-a");
    return Translation_new("uname", args, "Show system information", PermissionLevel.READ_ONLY, "uname displays system identification");
}

fn translate_network_info(intent) {
    var args = vec_new();
    vec_push(args, "addr");
    vec_push(args, "show");
    return Translation_new("ip", args, "Show network configuration", PermissionLevel.READ_ONLY, "ip addr show displays network interfaces and addresses");
}

fn translate_disk_usage(intent) {
    var args = vec_new();
    vec_push(args, "-h");
    if (intent.field1 != 0) { vec_push(args, intent.field1); }
    return Translation_new("df", args, "Show disk usage", PermissionLevel.READ_ONLY, "df reports filesystem disk space usage");
}

fn translate_install_package(intent) {
    var args = vec_new();
    vec_push(args, "install");
    vec_push(args, "-y");
    var pkgs = intent.vec1;
    var npkgs = vec_len(pkgs);
    for (var i = 0; i < npkgs; i = i + 1) {
        vec_push(args, vec_get(pkgs, i));
    }
    return Translation_new("apt", args, "Install packages", PermissionLevel.ADMIN, "apt install downloads and installs system packages");
}

fn translate_shell_command(intent) {
    var args = vec_new();
    if (intent.vec1 != 0) {
        var n = vec_len(intent.vec1);
        for (var i = 0; i < n; i = i + 1) {
            vec_push(args, vec_get(intent.vec1, i));
        }
    }
    var perm = analyze_command_permission(intent.field1, args, vec_len(args));
    return Translation_new(intent.field1, args, "Execute shell command", perm, "Direct command execution");
}

// --- Git translators ---

fn translate_git_commit(intent) {
    var args = vec_new();
    vec_push(args, "commit");
    if (intent.int1 == 1) { vec_push(args, "-a"); }
    if (intent.field1 != 0) {
        vec_push(args, "-m");
        vec_push(args, intent.field1);
    }
    return Translation_new("git", args, "Commit changes", PermissionLevel.USER_WRITE, "git commit records changes to the repository");
}

fn translate_git_diff(intent) {
    var args = vec_new();
    vec_push(args, "diff");
    if (intent.int1 == 1) { vec_push(args, "--staged"); }
    return Translation_new("git", args, "Show differences", PermissionLevel.READ_ONLY, "git diff shows changes between commits, trees, or working tree");
}

fn translate_git_branch(intent) {
    var args = vec_new();
    vec_push(args, "branch");
