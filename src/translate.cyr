fn translate_git_merge(intent) {
    var args = vec_new();
    vec_push(args, "merge");
    if (intent.field1 != 0) { vec_push(args, intent.field1); }
    return Translation_new("git", args, "Merge branches", PermissionLevel.USER_WRITE, "git merge joins two or more development histories together");
