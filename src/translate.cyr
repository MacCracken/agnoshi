fn translate_list_files(intent) {
    var args = vec_new();
    var opts = load64(intent + 40);
    if (list_options_long(opts) == 1) { vec_push(args, "-l"); }
    if (list_options_all(opts) == 1) { vec_push(args, "-a"); }
    if (list_options_human(opts) == 1) { vec_push(args, "-h"); }
    if (list_options_time(opts) == 1) { vec_push(args, "-t"); }
    if (list_options_recursive(opts) == 1) { vec_push(args, "-R"); }
    if (load64(intent + 8) != 0) { vec_push(args, load64(intent + 8)); }
    return Translation_new(
    "ls",
    args,
    "List files and directories",
    PermissionLevel.READ_ONLY,
    "ls shows directory contents"
    );
}
fn translate_show_file(intent) {
    if (load64(intent + 8) == 0) { return translate_unknown(intent); }
    if (is_safe_path(load64(intent + 8)) == 0) { return translate_unknown(intent); }
    var args = vec_new();
    vec_push(args, load64(intent + 8));
    return Translation_new(
    "cat",
    args,
    "Display file contents",
    PermissionLevel.READ_ONLY,
    "cat outputs file contents to stdout"
    );
}
fn translate_find_files(intent) {
    var args = vec_new();
    if (load64(intent + 16) != 0) {
        if (is_safe_path(load64(intent + 16)) == 0) { return translate_unknown(intent); }
        vec_push(args, load64(intent + 16));
    } else {
        vec_push(args, ".");
    }
    vec_push(args, "-name");
    if (load64(intent + 8) != 0) {
        if (is_safe_arg(load64(intent + 8)) == 0) { return translate_unknown(intent); }
        vec_push(args, load64(intent + 8));
    } else {
        vec_push(args, "*");
    }
    return Translation_new(
    "find",
    args,
    "Search for files by name",
    PermissionLevel.READ_ONLY,
    "find searches directory trees for matching files"
    );
}
fn translate_search_content(intent) {
    var args = vec_new();
