        vec_push(args, load64(intent + 8));
    }
    if (load64(intent + 16) != 0) {
        if (is_safe_path(load64(intent + 16)) == 0) { return translate_unknown(intent); }
        vec_push(args, load64(intent + 16));
    }
    return Translation_new(
    "grep",
    args,
    "Search file contents",
    PermissionLevel.READ_ONLY,
    "grep searches for text patterns in files"
    );
}
