fn translate_install_package(intent) {
    var args = vec_new();
    vec_push(args, "install");
    vec_push(args, "-y");
    var pkgs = load64(intent + 56);
    var npkgs = vec_len(pkgs);
    for (var i = 0; i < npkgs; i = i + 1) {
        vec_push(args, vec_get(pkgs, i));
    }
    return Translation_new(
    "apt",
    args,
    "Install packages",
    PermissionLevel.ADMIN,
    "apt install downloads and installs system packages"
    );
}
fn translate_shell_command(intent) {
    var args = vec_new();
    if (load64(intent + 56) != 0) {
        var n = vec_len(load64(intent + 56));
        for (var i = 0; i < n; i = i + 1) {
            vec_push(args, vec_get(load64(intent + 56), i));
        }
    }
    var perm = analyze_command_permission(load64(intent + 8), args, vec_len(args));
    return Translation_new(load64(intent + 8), args, "Execute shell command", perm, "Direct command execution");
}
fn translate_git_commit(intent) {
    var args = vec_new();
    vec_push(args, "commit");
    if (load64(intent + 40) == 1) { vec_push(args, "-a"); }
    if (load64(intent + 8) != 0) {
        if (is_safe_commit_message(load64(intent + 8)) == 0) {
            return translate_unknown(intent);
        }
        vec_push(args, "-m");
        vec_push(args, load64(intent + 8));
    }
    return Translation_new(
    "git",
    args,
    "Commit changes",
    PermissionLevel.USER_WRITE,
    "git commit records changes to the repository"
    );
}
