fn translate_git_push(intent) {
    var args = vec_new();
    vec_push(args, "push");
    if (intent.field1 != 0) { vec_push(args, intent.field1); }
    return Translation_new("git", args, "Push commits to remote", PermissionLevel.USER_WRITE, "git push uploads local commits to a remote repository");
}

fn translate_git_pull(intent) {
    var args = vec_new();
    vec_push(args, "pull");
    return Translation_new("git", args, "Pull from remote", PermissionLevel.USER_WRITE, "git pull fetches and merges changes from a remote repository");
}

fn translate_git_checkout(intent) {
    var args = vec_new();
    vec_push(args, "checkout");
    if (intent.field1 != 0) { vec_push(args, intent.field1); }
    return Translation_new("git", args, "Switch branches", PermissionLevel.USER_WRITE, "git checkout switches branches or restores files");
