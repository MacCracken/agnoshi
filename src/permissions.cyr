enum PermissionLevel {
    SAFE = 0;
    READ_ONLY = 1;
    USER_WRITE = 2;
    SYSTEM_WRITE = 3;
    ADMIN = 4;
    BLOCKED = 5;
}
fn perm_requires_approval(level) {
    return (level == PermissionLevel.SYSTEM_WRITE) || (level == PermissionLevel.ADMIN) || (level == PermissionLevel.BLOCKED);
}
fn perm_ai_allowed(level) {
    return (level != PermissionLevel.BLOCKED);
}
fn check_permission(user, required) {
    if (streq(user, "root") == 1) {
        return 1;
    }
    if (required == PermissionLevel.SAFE) { return 1; }
    if (required == PermissionLevel.READ_ONLY) { return 1; }
    if (required == PermissionLevel.USER_WRITE) { return 1; }
    if (required == PermissionLevel.SYSTEM_WRITE) { return 0; }
    if (required == PermissionLevel.ADMIN) { return 0; }
    if (required == PermissionLevel.BLOCKED) { return 0; }
    return 0; 
}
fn is_blocked_command(cmd) {
    if (streq(cmd, "dd") == 1) { return 1; }
    if (streq(cmd, "mkfs") == 1) { return 1; }
    if (streq(cmd, "fdisk") == 1) { return 1; }
    if (streq(cmd, "parted") == 1) { return 1; }
    if (streq(cmd, "chmod") == 1) { return 1; }
    if (streq(cmd, "chown") == 1) { return 1; }
    if (streq(cmd, "chgrp") == 1) { return 1; }
    if (streq(cmd, "shred") == 1) { return 1; }
    return 0;
}
