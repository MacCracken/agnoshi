    if (streq(cmd, "su") == 1) { return 1; }
    if (streq(cmd, "swapoff") == 1) { return 1; }
    if (streq(cmd, "swapon") == 1) { return 1; }
    if (streq(cmd, "mknod") == 1) { return 1; }
    return 0;
}
