    if (streq(cmd, "killall") == 1) { return 1; }
    if (streq(cmd, "pkill") == 1) { return 1; }
    if (streq(cmd, "reboot") == 1) { return 1; }
    if (streq(cmd, "shutdown") == 1) { return 1; }
    if (streq(cmd, "poweroff") == 1) { return 1; }
    if (streq(cmd, "halt") == 1) { return 1; }
    if (streq(cmd, "iptables") == 1) { return 1; }
    if (streq(cmd, "ip6tables") == 1) { return 1; }
    if (streq(cmd, "nft") == 1) { return 1; }
    if (streq(cmd, "ufw") == 1) { return 1; }
    if (streq(cmd, "crontab") == 1) { return 1; }
