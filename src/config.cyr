include "lib/str.cyr"
var MCP_BASE_URL_DATA = "http://127.0.0.1:8090";
var LLM_BASE_URL_DATA = "http://127.0.0.1:8088";
struct ShellConfig {
    default_mode;
    history_size;
    ai_enabled;
    auto_approve_low;
    approval_timeout;
    show_explanations;
    show_ai_mode;
    show_git;
    show_exit_status;
}
fn ShellConfig_default() {
    var p = alloc(72);
    store64(p, Mode.AI_ASSISTED);
    store64(p + 8, 10000);
    store64(p + 16, 1);
    store64(p + 24, 0);
    store64(p + 32, 300);
    store64(p + 40, 1);
    store64(p + 48, 1);
    store64(p + 56, 1);
    store64(p + 64, 1);
    return p;
}
