struct Session {
    mode_mgr;
    interpreter;
    approval;
    history;
    checkpoint;
    output_fmt;
    prompt_ctx;
    config;
    security;
    cwd;
    running;
}
fn Session_new(config, security, initial_mode) {
    var allow_switch = 1;
    var mode_mgr = ModeManager_new(initial_mode, allow_switch);
    var interpreter = Interpreter_new();
    var approval = ApprovalManager_new();
    ApprovalManager_set_auto_approve(approval, load64(config + 24));
    var cwd_buf[4096];
    syscall(SYS_GETCWD, &cwd_buf, 4095);
    var cwd = str_from(&cwd_buf);
    var username = SecurityContext_username(security);
    var prompt_ctx = PromptContext_new(cwd, username, initial_mode);
    var history_path = str_from("/tmp/.agnsh_history");
    var home = getenv("HOME");
    if (home != 0) {
        history_path = str_cat(home, "/.agnsh_history");
    }
    var history = CommandHistory_new(history_path, load64(config + 8));
    var checkpoint = CheckpointManager_new();
    var output_fmt = OutputFormatter_default();
    var p = alloc(88);
    store64(p, mode_mgr);
    store64(p + 8, interpreter);
    store64(p + 16, approval);
    store64(p + 24, history);
    store64(p + 32, checkpoint);
    store64(p + 40, output_fmt);
    store64(p + 48, prompt_ctx);
    store64(p + 56, config);
    store64(p + 64, security);
    store64(p + 72, cwd);
    store64(p + 80, 1);
    return p;
}
fn Session_run_interactive(self) {
    ui_show_welcome();
    while (load64(self + 80) == 1) {
        var prompt = prompt_render(load64(self + 48));
        var input = read_input_line(prompt);
        if (input == 0) {
            break;
        }
        if (str_len(input) == 0) { continue; }
        if (str_len(input) > 65536) {
            ui_show_error("Input too long (max 64KB)");
            continue;
        }
        CommandHistory_add(load64(self + 24), input);
        Session_process_input(self, input);
    }
    CommandHistory_save(load64(self + 24));
    ui_show_goodbye();
    return 0;
}
fn Session_execute_one_shot(self, command) {
    Session_process_input(self, command);
    return 0;
}
fn Session_process_input(self, input) {
    var handled = Session_handle_builtin(self, input);
    if (handled != 0) { return 0; }
    var mode = ModeManager_current(load64(self));
    match mode {
        2 => { Session_execute_shell(self, input); }
        1 => { Session_execute_assisted(self, input); }
        0 => { Session_execute_autonomous(self, input); }
        3 => { Session_execute_strict(self, input); }
    }
    return 0;
}
fn Session_handle_builtin(self, input) {
    var trimmed = str_trim(input);
    if (streq(trimmed, "exit") == 1 || streq(trimmed, "quit") == 1) {
        store64(self + 80, 0);
        return 1;
    }
    if (streq(trimmed, "help") == 1) {
        ui_show_help();
        return 1;
    }
    if (streq(trimmed, "clear") == 1) {
        ui_clear_screen();
        return 1;
    }
    if (streq(trimmed, "mode") == 1) {
        ui_show_mode(ModeManager_current(load64(self)));
        return 1;
    }
    if (str_starts_with(trimmed, "mode ") == 1) {
        var mode_name = str_substr(trimmed, 5, str_len(trimmed));
        mode_name = str_trim(mode_name);
        var new_mode = 0 - 1;
        if (streq(mode_name, "human") == 1) { new_mode = Mode.HUMAN; }
        if (streq(mode_name, "assist") == 1) { new_mode = Mode.AI_ASSISTED; }
        if (streq(mode_name, "auto") == 1) { new_mode = Mode.AI_AUTONOMOUS; }
        if (streq(mode_name, "strict") == 1) { new_mode = Mode.STRICT; }
        if (new_mode >= 0) {
            var result = ModeManager_switch(load64(self), new_mode);
            if (result == 0) {
                store64(load64(self + 48) + 32, new_mode);
                ui_show_mode(new_mode);
            } else {
                ui_show_error("Mode switching is disabled");
            }
        } else {
            ui_show_error("Unknown mode. Use: human, assist, auto, strict");
        }
        return 1;
    }
    if (streq(trimmed, "history") == 1) {
        ui_show_history(load64(self + 24));
        return 1;
    }
    if (streq(trimmed, "undo") == 1) {
        var result = CheckpointManager_undo_last(load64(self + 32));
        if (result != 0) {
            ui_show_info(result);
        } else {
            ui_show_info("Nothing to undo.");
        }
        return 1;
    }
    return 0;
}
fn Session_execute_shell(self, input) {
    var cmd_out[1];
    var args = vec_new();
    var argc = split_command_line(input, &cmd_out, args);
    var cmd = load64(&cmd_out);
    if (argc < 0 || cmd == 0) {
        ui_show_error("Failed to parse command");
        return 0;
    }
    if (streq(cmd, "cd") == 1) {
        if (vec_len(args) > 0) {
            var dir = vec_get(args, 0);
            if (str_byte_at(dir, 0) == 126) {
                var home = getenv("HOME");
                if (home != 0) {
                    dir = str_cat(home, str_substr(dir, 1, str_len(dir)));
                }
            }
            var result = syscall(SYS_CHDIR, str_data(dir));
            if (result == 0) {
                var cwd_buf[4096];
                syscall(SYS_GETCWD, &cwd_buf, 4095);
                store64(self + 72, str_from(&cwd_buf));
                store64(load64(self + 48), load64(self + 72));
                store64(load64(self + 48) + 40, 0);
            } else {
                ui_show_error(str_cat(str_from("cd: no such directory: "), dir));
                store64(load64(self + 48) + 40, 1);
            }
        }
        return 0;
    }
    if (streq(cmd, "rm") == 1) {
        var checkpoint_ok = 1;
        for (var i = 0; i < vec_len(args); i = i + 1) {
            var arg = vec_get(args, i);
            if (str_byte_at(arg, 0) != 45) {
                var cp_result = CheckpointManager_checkpoint_remove(load64(self + 32), arg);
                if (cp_result == 0) { checkpoint_ok = 0; }
            }
        }
        if (checkpoint_ok == 0) {
            ui_show_warning("Could not checkpoint some files -- undo may not work for this operation.");
        }
    }
    if (streq(cmd, "mv") == 1) {
        if (vec_len(args) >= 2) {
            CheckpointManager_checkpoint_move(load64(self + 32),
            vec_get(args, 0), vec_get(args, 1));
        }
    }
    var exit_code = execute_command(cmd, args, vec_len(args));
    store64(load64(self + 48) + 40, exit_code);
    return 0;
}
fn Session_execute_assisted(self, input) {
    var intent = Interpreter_parse(load64(self + 8), input);
    if (load64(intent) == IntentTag.QUESTION) {
        ui_show_info("Questions require an LLM endpoint. Try 'mode human' for direct commands.");
        return 0;
    }
    if (load64(intent) == IntentTag.UNKNOWN) {
        ui_show_warning("Could not understand. Try rephrasing or use 'help'.");
        return 0;
    }
    var translation = Interpreter_translate(load64(self + 8), intent);
    ui_show_proposed_action(load64(translation), load64(translation + 8),
    vec_len(load64(translation + 8)), load64(translation + 16));
    if (perm_requires_approval(load64(translation + 24)) == 1) {
        var risk = risk_from_permission(load64(translation + 24));
        var response = ApprovalManager_request(load64(self + 16),
        load64(translation), load64(translation + 8), vec_len(load64(translation + 8)), risk);
        if (response != ApprovalResponse.APPROVED && response != ApprovalResponse.APPROVED_ONCE) {
            ui_show_info("Command denied.");
            return 0;
        }
    }
    Session_execute_translation(self, translation);
    return 0;
}
fn Session_execute_autonomous(self, input) {
    var intent = Interpreter_parse(load64(self + 8), input);
    var translation = Interpreter_translate(load64(self + 8), intent);
    if (perm_ai_allowed(load64(translation + 24)) == 0) {
        ui_show_error("AI is not allowed to execute this command.");
        return 0;
    }
    if (perm_requires_approval(load64(translation + 24)) == 1) {
        ui_show_warning("Elevated permissions required -- falling back to assisted mode.");
        Session_execute_assisted(self, input);
        return 0;
    }
    Session_execute_translation(self, translation);
    return 0;
}
fn Session_execute_strict(self, input) {
    var intent = Interpreter_parse(load64(self + 8), input);
    var translation = Interpreter_translate(load64(self + 8), intent);
    var risk = risk_from_permission(load64(translation + 24));
    var response = ApprovalManager_request(load64(self + 16),
    load64(translation), load64(translation + 8), vec_len(load64(translation + 8)), risk);
    if (response != ApprovalResponse.APPROVED && response != ApprovalResponse.APPROVED_ONCE) {
        ui_show_info("Command denied.");
        return 0;
    }
    Session_execute_translation(self, translation);
    return 0;
}
fn Session_execute_translation(self, translation) {
    if (streq(load64(translation), "cd") == 1) {
        if (vec_len(load64(translation + 8)) > 0) {
            var dir = vec_get(load64(translation + 8), 0);
            var result = syscall(SYS_CHDIR, str_data(dir));
            if (result == 0) {
                var cwd_buf[4096];
                syscall(SYS_GETCWD, &cwd_buf, 4095);
                store64(self + 72, str_from(&cwd_buf));
                store64(load64(self + 48), load64(self + 72));
                store64(load64(self + 48) + 40, 0);
            } else {
                ui_show_error(str_cat(str_from("cd: no such directory: "), dir));
                store64(load64(self + 48) + 40, 1);
            }
        }
        return 0;
    }
    if (streq(load64(translation), "rm") == 1) {
        var nargs = vec_len(load64(translation + 8));
        var checkpoint_ok = 1;
        for (var i = 0; i < nargs; i = i + 1) {
            var arg = vec_get(load64(translation + 8), i);
            if (str_byte_at(arg, 0) != 45) {
                var cp_result = CheckpointManager_checkpoint_remove(load64(self + 32), arg);
                if (cp_result == 0) { checkpoint_ok = 0; }
            }
        }
        if (checkpoint_ok == 0) {
            ui_show_warning("Could not checkpoint some files -- undo may not work.");
        }
    }
    var exit_code = execute_command(load64(translation), load64(translation + 8), vec_len(load64(translation + 8)));
    store64(load64(self + 48) + 40, exit_code);
    return 0;
}
